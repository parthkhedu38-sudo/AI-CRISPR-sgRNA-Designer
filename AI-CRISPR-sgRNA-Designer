        "def train_random_forest(X_train: pd.DataFrame,\n",
        "                        y_train: pd.Series,\n",
        "                        n_estimators: int = 200,\n",
        "                        max_depth: int = None,\n",
        "                        min_samples_leaf: int = 2,\n",
        "                        random_state: int = 42) -> RandomForestRegressor:\n",
        "    \"\"\"\n",
        "    Train a RandomForestRegressor on the training split.\n",
        "\n",
        "    Key hyper-parameter choices:\n",
        "        n_estimators=200    — large enough for stable variance estimates\n",
        "        max_depth=None      — trees grown until leaves are pure (regularised\n",
        "                              implicitly by min_samples_leaf)\n",
        "        min_samples_leaf=2  — prevents single-sample leaves, reduces overfitting\n",
        "        n_jobs=-1           — use all CPU cores in Colab\n",
        "\n",
        "    Parameters\n",
        "    ----------\n",
        "    X_train          : pd.DataFrame — training features\n",
        "    y_train          : pd.Series    — training targets\n",
        "    n_estimators     : int          — number of trees in the forest\n",
        "    max_depth        : int | None   — maximum tree depth (None = unlimited)\n",
        "    min_samples_leaf : int          — minimum samples per leaf node\n",
        "    random_state     : int          — seed for reproducibility\n",
        "\n",
        "    Returns\n",
        "    -------\n",
        "    RandomForestRegressor  — fitted model\n",
        "    \"\"\"\n",
        "    print(f\"[train] Fitting RandomForest ({n_estimators} trees) …\")\n",
        "\n",
        "    model = RandomForestRegressor(\n",
        "        n_estimators=n_estimators,\n",
        "        max_depth=max_depth,\n",
        "        min_samples_leaf=min_samples_leaf,\n",
        "        random_state=random_state,\n",
        "        n_jobs=-1           # parallelise across all available cores\n",
        "    )\n",
        "\n",
        "    model.fit(X_train, y_train)\n",
        "    print(\"[train] Training complete.\\n\")\n",
        "    return model"
      ],
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
