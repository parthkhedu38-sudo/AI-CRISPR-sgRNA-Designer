        "                color=C_SCATTER, edgecolors=\"none\",\n",
        "                label=\"Predictions\")\n",
        "\n",
        "    # Perfect-prediction diagonal\n",
        "    lo = min(y_true.min(), y_pred.min()) - 0.02\n",
        "    hi = max(y_true.max(), y_pred.max()) + 0.02\n",
        "    ax1.plot([lo, hi], [lo, hi],\n",
        "             color=C_PERFECT, linewidth=1.6,\n",
        "             linestyle=\"--\", label=\"Perfect fit\")\n",
        "\n",
        "    # Annotate with test-set metrics\n",
        "    r2_str  = f\"R²  = {test_m['r2']:.4f}\"\n",
        "    mse_str = f\"MSE = {test_m['mse']:.6f}\"\n",
        "    ax1.text(0.05, 0.93, r2_str,  transform=ax1.transAxes,\n",
        "             fontsize=10, color=\"#1E293B\",\n",
        "             bbox=dict(boxstyle=\"round,pad=0.3\", fc=\"white\", alpha=0.7))\n",
        "    ax1.text(0.05, 0.85, mse_str, transform=ax1.transAxes,\n",
        "             fontsize=10, color=\"#1E293B\",\n",
        "             bbox=dict(boxstyle=\"round,pad=0.3\", fc=\"white\", alpha=0.7))\n",
        "\n",
        "    ax1.set_xlim(lo, hi)\n",
        "    ax1.set_ylim(lo, hi)\n",
