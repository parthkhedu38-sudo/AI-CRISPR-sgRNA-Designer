        "PENALTY_CONFIG = {\n",
        "    # GC content boundaries — outside this band, efficiency drops\n",
        "    \"gc_low\"       : 0.30,    # < 30 % GC is too AT-rich → weak R-loop\n",
        "    \"gc_high\"      : 0.80,    # > 80 % GC risks secondary structure / G-quadruplex\n",
        "    \"gc_ideal_low\" : 0.45,    # ideal window lower bound\n",
        "    \"gc_ideal_high\": 0.65,    # ideal window upper bound\n",
        "\n",
        "    # Seed GC — the PAM-proximal 10 nt must be GC-stable for cleavage\n",
        "    \"seed_gc_min\"  : 0.30,    # below this → severe cleavage penalty\n",
        "\n",
        "    # Homopolymer — T4 or longer terminates RNA Pol III\n",
        "    \"hp_max\"       : 3,       # runs > 3 are penalised\n",
        "\n",
        "    # Penalty scaling weights (must sum ≤ 1 for the penalty to stay in [0,1])\n",
        "    \"w_gc\"         : 0.40,    # GC penalty weight\n",
        "    \"w_seed\"       : 0.35,    # seed-GC penalty weight\n",
        "    \"w_hp\"         : 0.25,    # homopolymer penalty weight\n",
        "}\n",
        "\n",
        "\n",
        "def compute_gc_penalty(gc: float, cfg: dict = PENALTY_CONFIG) -> float:\n",
        "    \"\"\"\n",
        "    Penalise GC content that falls outside the ideal [0.45, 0.65] window.\n",
        "\n",
        "    Penalty logic (piecewise linear):\n",
        "        gc < gc_low          → max penalty 1.0   (extremely AT-rich, no R-loop)\n",
        "        gc_low  ≤ gc < ideal → linear ramp from 1 → 0\n",
        "        ideal window         → 0                 (no penalty)\n",
        "        ideal < gc ≤ gc_high → linear ramp from 0 → 0.5  (secondary structure risk)\n",
        "        gc > gc_high         → max penalty 1.0   (G-quadruplex risk)\n",
        "\n",
        "    Biological basis: Doench et al. (2016) and Xu et al. (2015) both show\n",
        "    a U-shaped efficiency curve centred near 50-60 % GC content.\n",
        "\n",
        "    Parameters\n",
        "    ----------\n",
        "    gc  : float  — GC fraction [0, 1]\n",
        "    cfg : dict   — PENALTY_CONFIG\n",
        "\n",
        "    Returns\n",
        "    -------\n",
        "    float in [0, 1]  — 0 = no penalty, 1 = maximum penalty\n",
        "    \"\"\"\n",
        "    lo, hi       = cfg[\"gc_low\"],       cfg[\"gc_high\"]\n",
        "    ideal_lo, ideal_hi = cfg[\"gc_ideal_low\"], cfg[\"gc_ideal_high\"]\n",
        "\n",
        "    if gc < lo:\n",
        "        return 1.0\n",
        "    elif gc < ideal_lo:\n",
        "        # linear ramp: gc_low → 1.0,  ideal_lo → 0.0\n",
        "        return 1.0 - (gc - lo) / (ideal_lo - lo)\n",
        "    elif gc <= ideal_hi:\n",
        "        return 0.0\n",
        "    elif gc <= hi:\n",
        "        # linear ramp: ideal_hi → 0.0,  gc_high → 0.5\n",
        "        return 0.5 * (gc - ideal_hi) / (hi - ideal_hi)\n",
        "    else:\n",
        "        return 1.0\n",
        "\n",
        "\n",
        "def compute_seed_penalty(seed_gc: float, cfg: dict = PENALTY_CONFIG) -> float:\n",
        "    \"\"\"\n",
        "    Penalise low seed-region GC content.\n",
        "\n",
        "    The seed region (PAM-proximal 10 nt, positions 11-20) must form a\n",
        "    stable RNA-DNA hybrid for Cas9 cleavage.  AT-rich seeds are weak.\n",
        "\n",
        "    Penalty is linear from seed_gc = 0 (penalty = 1) to\n",
        "    seed_gc = seed_gc_min (penalty = 0).  Above seed_gc_min → no penalty.\n",
        "\n",
        "    Biological basis: Wang et al. (2014) showed that seed region GC < 30%\n",
        "    correlates strongly with reduced cutting efficiency.\n",
        "\n",
        "    Parameters\n",
        "    ----------\n",
        "    seed_gc : float  — GC fraction of the last 10 nt [0, 1]\n",
        "    cfg     : dict\n",
        "\n",
        "    Returns\n",
        "    -------\n",
        "    float in [0, 1]\n",
        "    \"\"\"\n",
        "    threshold = cfg[\"seed_gc_min\"]\n",
        "    if seed_gc >= threshold:\n",
        "        return 0.0\n",
        "    return 1.0 - (seed_gc / threshold)\n",
        "\n",
        "\n",
        "def compute_homopolymer_penalty(hp_run: int, cfg: dict = PENALTY_CONFIG) -> float:\n",
        "    \"\"\"\n",
        "    Penalise long homopolymer runs (especially T-runs).\n",
        "\n",
        "    T4+ is an RNA Pol III termination signal; A-runs form slippage\n",
        "    structures; G-runs risk G-quadruplex formation in the guide RNA.\n",
        "    Any run > hp_max nucleotides triggers a graded penalty.\n",
        "\n",
        "    Penalty grows linearly from hp_max + 1 (small) to 20 (maximum = 1).\n",
        "\n",
        "    Parameters\n",
        "    ----------\n",
        "    hp_run : int   — length of the longest homopolymer run\n",
        "    cfg    : dict\n",
        "\n",
        "    Returns\n",
        "    -------\n",
        "    float in [0, 1]\n",
        "    \"\"\"\n",
        "    max_allowed = cfg[\"hp_max\"]\n",
        "    if hp_run <= max_allowed:\n",
        "        return 0.0\n",
        "    # normalise excess run length to [0, 1]\n",
        "    excess = hp_run - max_allowed\n",
        "    return min(excess / (20 - max_allowed), 1.0)\n",
        "\n",
        "\n",
        "def compute_biological_penalty(gc: float,\n",
        "                                seed_gc: float,\n",
        "                                hp_run: int,\n",
        "                                cfg: dict = PENALTY_CONFIG) -> float:\n",
        "    \"\"\"\n",
        "    Combine the three sub-penalties into a single composite penalty ∈ [0, 1].\n",
        "\n",
        "    Composite = w_gc × P_gc + w_seed × P_seed + w_hp × P_hp\n",
        "\n",
        "    The weights reflect relative importance of each rule based on\n",
        "    published CRISPR guide design literature:\n",
        "        GC content    (40%) — primary efficiency determinant\n",
        "        Seed GC       (35%) — critical for cleavage initiation\n",
        "        Homopolymer   (25%) — structural / transcriptional issue\n",
        "\n",
        "    Parameters\n",
        "    ----------\n",
        "    gc      : float — overall GC fraction\n",
        "    seed_gc : float — seed-region GC fraction\n",
        "    hp_run  : int   — longest homopolymer run length\n",
        "\n",
        "    Returns\n",
        "    -------\n",
        "    float in [0, 1]  — 0 = biologically ideal, 1 = maximally penalised\n",
        "    \"\"\"\n",
        "    p_gc   = compute_gc_penalty(gc,     cfg) * cfg[\"w_gc\"]\n",
        "    p_seed = compute_seed_penalty(seed_gc, cfg) * cfg[\"w_seed\"]\n",
        "    p_hp   = compute_homopolymer_penalty(hp_run, cfg) * cfg[\"w_hp\"]\n",
        "    return min(p_gc + p_seed + p_hp, 1.0)\n",
        "\n",
        "\n",
