        "if __name__ == \"__main__\":\n",
        "\n",
        "    np.random.seed(42);  random.seed(42)\n",
        "    BASES = \"ATGC\"\n",
        "\n",
        "    def _gc(s):  return (s.count(\"G\") + s.count(\"C\")) / len(s)\n",
        "    def _sgc(s): return (s[-10:].count(\"G\") + s[-10:].count(\"C\")) / 10\n",
        "    def _hp(s):\n",
        "        mx = cr = 1\n",
        "        for i in range(1, len(s)):\n",
        "            cr = cr+1 if s[i]==s[i-1] else 1; mx = max(mx, cr)\n",
        "        return mx\n",
        "    def _ent(s):\n",
        "        c = Counter(s); h = 0\n",
        "        for b in \"ATGC\":\n",
        "            p = c.get(b,0)/len(s)\n",
        "            if p: h -= p*math.log2(p)\n",
        "        return h\n",
        "    def _di(s):\n",
        "        n = len(s)-1; c = Counter(s[i:i+2] for i in range(n))\n",
        "        return {a+b: c.get(a+b,0)/n for a in \"ATGC\" for b in \"ATGC\"}\n",
        "    def _ohe(s):\n",
        "        d = {}\n",
        "        for pi, base in enumerate(s, 1):\n",
        "            for b in \"ATGC\":\n",
        "                d[f\"pos{pi:02d}_{b}\"] = 1 if base == b else 0\n",
        "        return d\n",
        "\n",
        "    N = 400\n",
        "    rows = []\n",
        "    for _ in range(N):\n",
        "        # Deliberately inject some biologically-bad guides\n",
        "        if random.random() < 0.15:\n",
        "            # Very AT-rich → should be penalised\n",
        "            s = \"\".join(random.choices(\"AT\", k=20))\n",
        "        elif random.random() < 0.10:\n",
        "            # Long homopolymer → should be penalised\n",
        "            base = random.choice(BASES)\n",
        "            s    = base * random.randint(5, 8) + \\\n",
        "                   \"\".join(random.choices(BASES, k=20 - random.randint(5,8)))\n",
        "            s    = s[:20]\n",
        "        else:\n",
        "            s = \"\".join(random.choices(BASES, k=20))\n",
        "\n",
        "        eff = float(np.clip(\n",
        "            0.50 * _sgc(s) + 0.25 * _gc(s) +\n",
        "            0.10 * (s[0] == \"G\") + 0.08 * (s[16] in \"GC\") +\n",
        "            np.random.normal(0, 0.09), 0, 1))\n",
        "\n",
        "        r = {\"sgRNA_sequence\": s, \"gene\": random.choice([\"TP53\",\"KRAS\",\"BRCA1\"]),\n",
        "             \"gc_content\": _gc(s), \"seed_gc_content\": _sgc(s),\n",
        "             \"longest_homopolymer\": _hp(s), \"sequence_entropy\": _ent(s)}\n",
        "        r.update({f\"dinuc_{k}\": v for k, v in _di(s).items()})\n",
        "        r.update(_ohe(s))\n",
        "        r[\"efficiency_score\"] = round(eff, 4)\n",
        "        rows.append(r)\n",
        "\n",
        "    enhanced_dataset = pd.DataFrame(rows)\n",
        "    print(f\"Synthetic enhanced_dataset: {enhanced_dataset.shape}\\n\")\n",
