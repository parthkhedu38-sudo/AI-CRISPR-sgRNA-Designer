        "def run_regularization_pipeline(\n",
        "        enhanced_dataset: pd.DataFrame,\n",
        "        target_col: str  = \"efficiency_score\",\n",
        "        drop_cols: tuple = (\"gene\", \"sgRNA_sequence\"),\n",
        "        config:    dict  = CV_CONFIG,\n",
        "        alpha:     float = 0.25,\n",
        "        beta:      float = 0.15,\n",
        ") -> dict:\n",
        "    \"\"\"\n",
        "    End-to-end Stage 6 orchestration.\n",
        "\n",
        "    Parameters\n",
        "    ----------\n",
        "    enhanced_dataset : pd.DataFrame\n",
        "        Stage 4 output (bio + positional features + efficiency_score).\n",
        "        Must contain gc_content, seed_gc_content, longest_homopolymer.\n",
        "    target_col : str\n",
        "    drop_cols  : tuple\n",
        "    config     : dict   — CV_CONFIG\n",
        "    alpha      : float  — target smoothing strength\n",
        "    beta       : float  — post-hoc penalty scale\n",
        "\n",
        "    Returns\n",
        "    -------\n",
        "    dict with keys:\n",
        "        'penalised_dataset' : dataset with bio_penalty column\n",
        "        'results'           : dict of label → CV results DataFrame\n",
        "        'summary'           : comparison summary DataFrame\n",
        "    \"\"\"\n",
        "    # ── Step 1: Add penalty column ────────────────────────────────────────────\n",
        "    penalised_dataset = add_penalty_column(enhanced_dataset)\n",
        "\n",
        "    # ── Step 2: Prepare X, y, penalties ──────────────────────────────────────\n",
        "    cols_to_drop = ([c for c in drop_cols if c in penalised_dataset.columns]\n",
        "                    + [target_col, \"bio_penalty\"])\n",
        "    X         = penalised_dataset.drop(columns=cols_to_drop)\n",
        "    y         = penalised_dataset[target_col]\n",
        "    penalties = penalised_dataset[\"bio_penalty\"]\n",
        "    print(f\"[pipeline] X: {X.shape}   y: {y.shape}\\n\")\n",
        "\n",
        "    # ── Step 3: Penalty explainability audit ──────────────────────────────────\n",
        "    explain_penalty_breakdown(penalised_dataset, n_examples=3)\n",
        "\n",
        "    # ── Step 4: Run all four approaches ──────────────────────────────────────\n",
        "    results = run_all_approaches(X, y, penalties, config, alpha=alpha, beta=beta)\n",
        "\n",
        "    # ── Step 5: Print summary ────────────────────────────────────────────────\n",
        "    summary = print_comparison_table(results)\n",
        "\n",
        "    # ── Step 6: Visualise ────────────────────────────────────────────────────\n",
        "    plot_regularization_comparison(results, summary, penalties, y)\n",
        "\n",
        "    return {\n",
        "        \"penalised_dataset\": penalised_dataset,\n",
        "        \"results\"          : results,\n",
        "        \"summary\"          : summary,\n",
        "    }"
