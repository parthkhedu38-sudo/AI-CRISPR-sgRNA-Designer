        "BASE_ORDER = [\"A\", \"T\", \"G\", \"C\"]\n",
        "SEQ_LENGTH = 20\n",
        "\n",
        "\n",
        "def one_hot_encode_sequence(seq: str) -> dict:\n",
        "    \"\"\"\n",
        "    One-hot encode a 20-nt sgRNA sequence into 80 binary features.\n",
        "\n",
        "    Encoding scheme:\n",
        "        For each position i ∈ {1 … 20} and each base b ∈ {A, T, G, C}:\n",
        "            feature  pos{i:02d}_{b}  =  1  if seq[i-1] == b  else  0\n",
        "\n",
        "    Column naming uses zero-padded integers (pos01 … pos20) so that\n",
        "    lexicographic and natural sort order coincide.\n",
        "\n",
        "    Biological note:\n",
        "        Positions 17–20 (seed region, PAM-proximal) are the most critical\n",
        "        for Cas9 cleavage. The model can learn elevated importance weights\n",
        "        for these columns automatically from data.\n",
        "\n",
        "    Parameters\n",
        "    ----------\n",
        "    seq : str  — validated 20-nt uppercase sequence\n",
        "\n",
        "    Returns\n",
        "    -------\n",
        "    dict  — 80 binary key-value pairs, e.g. {'pos01_A': 1, 'pos01_T': 0, …}\n",
        "    \"\"\"\n",
        "    features = {}\n",
        "    for pos_idx, base in enumerate(seq, start=1):          # pos_idx: 1-based\n",
        "        col_prefix = f\"pos{pos_idx:02d}\"                   # e.g. 'pos01'\n",
        "        for b in BASE_ORDER:\n",
        "            features[f\"{col_prefix}_{b}\"] = 1 if base == b else 0\n",
        "    return features\n",
        "\n",
        "\n",
        "def build_positional_matrix(df: pd.DataFrame,\n",
        "                             seq_col: str = \"sgRNA_sequence\") -> pd.DataFrame:\n",
        "    \"\"\"\n",
        "    Apply one_hot_encode_sequence() to every row and return a DataFrame.\n",
        "\n",
        "    Result shape: (n_sequences, 80)\n",
        "    Columns follow the pattern: pos01_A, pos01_T, pos01_G, pos01_C,\n",
        "                                 pos02_A, …, pos20_C\n",
        "\n",
        "    Parameters\n",
        "    ----------\n",
        "    df      : pd.DataFrame — dataframe containing the sequence column\n",
        "    seq_col : str          — name of the sequence column\n",
        "\n",
        "    Returns\n",
        "    -------\n",
        "    pd.DataFrame  — positional encoding matrix (all values ∈ {0, 1})\n",
        "    \"\"\"\n",
        "    print(\"[encode] Building positional one-hot matrix …\")\n",
        "    encoded = df[seq_col].apply(one_hot_encode_sequence)\n",
        "    pos_df  = pd.DataFrame(list(encoded))\n",
        "    print(f\"[encode] Positional matrix shape: {pos_df.shape}  \"\n",
        "          f\"(expected {len(df)} × {SEQ_LENGTH * len(BASE_ORDER)})\")\n",
        "    assert pos_df.shape[1] == SEQ_LENGTH * len(BASE_ORDER), \\\n",
        "        \"Unexpected number of positional columns.\"\n",
        "    print()\n",
        "    return pos_df"
