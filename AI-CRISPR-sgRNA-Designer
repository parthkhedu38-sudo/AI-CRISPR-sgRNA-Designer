        "\n",
        "    X_ext = feature_pipeline(external_df, seq_col=\"sgRNA_sequence\")\n",
        "    y_ext = external_df[\"efficiency_score\"].values\n",
        "\n",
        "\n",
        "    # ------------------------------\n",
        "    # Predict\n",
        "    # ------------------------------\n",
        "    print(\"Generating predictions...\")\n",
        "\n",
        "    y_pred = model.predict(X_ext)\n",
        "\n",
