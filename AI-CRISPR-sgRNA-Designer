    {
      "cell_type": "code",
      "source": [
        "VALID_BASES = set(\"ATGC\")\n",
        "REQUIRED_LENGTH = 20\n",
        "\n",
        "\n",
        "def _is_valid_sequence(seq: str) -> bool:\n",
        "    \"\"\"\n",
        "    Return True if seq is exactly 20 characters and contains only A/T/G/C.\n",
        "\n",
        "    Parameters\n",
        "    ----------\n",
        "    seq : str\n",
        "        Nucleotide sequence to validate.\n",
        "    \"\"\"\n",
        "    if not isinstance(seq, str):\n",
        "        return False\n",
        "    seq = seq.upper().strip()\n",
        "    return len(seq) == REQUIRED_LENGTH and set(seq).issubset(VALID_BASES)\n",
        "\n",
        "\n",
        "def validate_sequences(df: pd.DataFrame,\n",
        "                        seq_col: str = \"sgRNA_sequence\") -> pd.DataFrame:\n",
        "    \"\"\"\n",
        "    Validate all sequences in the dataframe and drop invalid rows.\n",
        "\n",
        "    Checks performed:\n",
        "        1. Length must equal 20.\n",
        "        2. Characters must be a subset of {A, T, G, C}.\n",
        "\n",
        "    Parameters\n",
        "    ----------\n",
        "    df     : pd.DataFrame  — input dataframe\n",
        "    seq_col: str           — column name holding sequences\n",
        "\n",
        "    Returns\n",
        "    -------\n",
        "    pd.DataFrame\n",
        "        Cleaned dataframe with sequences normalised to uppercase and\n",
        "        all invalid rows removed.\n",
        "    \"\"\"\n",
        "    # Normalise to uppercase in-place\n",
        "    df = df.copy()\n",
        "    df[seq_col] = df[seq_col].str.upper().str.strip()\n",
        "\n",
        "    valid_mask = df[seq_col].apply(_is_valid_sequence)\n",
        "    n_invalid = (~valid_mask).sum()\n",
        "\n",
        "    if n_invalid > 0:\n",
        "        print(f\"[validate] ⚠ Dropping {n_invalid} invalid sequence(s).\")\n",
        "        invalid_seqs = df.loc[~valid_mask, seq_col].tolist()\n",
        "        for s in invalid_seqs[:5]:          # show up to 5 examples\n",
        "            print(f\"           → '{s}'\")\n",
        "    else:\n",
        "        print(\"[validate] ✓ All sequences passed validation.\")\n",
        "\n",
        "    df = df[valid_mask].reset_index(drop=True)\n",
        "    print(f\"[validate] {len(df):,} sequences retained.\\n\")\n",
        "    return df\n"
