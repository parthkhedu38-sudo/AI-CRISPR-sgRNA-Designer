        "def apply_target_smoothing(y: pd.Series,\n",
        "                             penalties: pd.Series,\n",
        "                             alpha: float = 0.25) -> pd.Series:\n",
        "    \"\"\"\n",
        "    Blend raw efficiency labels toward biology-constrained values.\n",
        "\n",
        "    Formula:\n",
        "        y_reg[i]  =  (1 − α) × y[i]  +  α × y[i] × (1 − penalty[i])\n",
        "                  =  y[i] × (1 − α × penalty[i])\n",
        "\n",
        "    Intuition: for a guide with penalty = 0 (ideal biology), y_reg = y_raw.\n",
        "    For a guide with penalty = 1 (worst biology), y_reg = (1 − α) × y_raw.\n",
        "    With α = 0.25, the most penalised labels shrink by at most 25%.\n",
        "\n",
        "    This is NOT label corruption — it is a soft prior that says:\n",
        "    \"biology suggests this guide should underperform; discount its label\n",
        "    slightly so the model learns this regularised expectation.\"\n",
        "\n",
        "    Parameters\n",
        "    ----------\n",
        "    y         : pd.Series — raw efficiency_score\n",
        "    penalties : pd.Series — bio_penalty column (same index)\n",
        "    alpha     : float     — blend strength ∈ (0, 1), default 0.25\n",
        "\n",
        "    Returns\n",
        "    -------\n",
        "    pd.Series  — smoothed labels, same index as y\n",
        "    \"\"\"\n",
        "    y_reg = y * (1.0 - alpha * penalties)\n",
        "    delta = (y_reg - y).abs().mean()\n",
        "    print(f\"[smooth] Target smoothing applied  (α={alpha}).\")\n",
        "    print(f\"         Mean absolute label shift : {delta:.5f}\")\n",
        "    print(f\"         Max absolute label shift  : {(y_reg - y).abs().max():.5f}\\n\")\n",
        "    return y_reg.rename(\"efficiency_score_smoothed\")"
      ],
      "metadata": {
        "id": "oUuW-YAF6vcs"
      },
      "execution_count": null,
      "outputs": []
