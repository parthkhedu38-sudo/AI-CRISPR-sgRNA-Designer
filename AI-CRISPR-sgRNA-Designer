        "def split_data(X: pd.DataFrame,\n",
        "               y: pd.Series,\n",
        "               test_size: float = 0.2,\n",
        "               random_state: int = 42) -> tuple:\n",
        "    \"\"\"\n",
        "    Split data into training and test sets with stratification-safe shuffling.\n",
        "\n",
        "    An 80/20 split is used by default, which balances having enough training\n",
        "    data for the forest while keeping a meaningful held-out evaluation set.\n",
        "\n",
        "    Parameters\n",
        "    ----------\n",
        "    X            : pd.DataFrame — feature matrix\n",
        "    y            : pd.Series    — target vector\n",
        "    test_size    : float        — fraction of data reserved for testing\n",
        "    random_state : int          — seed for reproducibility\n",
        "\n",
        "    Returns\n",
        "    -------\n",
        "    X_train, X_test, y_train, y_test : four DataFrames / Series\n",
        "    \"\"\"\n",
        "    X_train, X_test, y_train, y_test = train_test_split(\n",
        "        X, y,\n",
        "        test_size=test_size,\n",
        "        random_state=random_state,\n",
        "        shuffle=True\n",
        "    )\n",
        "\n",
        "    print(f\"[split] Training set : {X_train.shape[0]:,} samples\")\n",
        "    print(f\"[split] Test set     : {X_test.shape[0]:,} samples\\n\")\n",
        "    return X_train, X_test, y_train, y_test\n"
      ],
      "execution_count": null,
      "outputs": []
    },
