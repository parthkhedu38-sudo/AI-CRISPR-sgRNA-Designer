        "def cross_validate_single_seed(X: pd.DataFrame,\n",
        "                                y: pd.Series,\n",
        "                                seed: int,\n",
        "                                config: dict = CV_CONFIG) -> pd.DataFrame:\n",
        "    \"\"\"\n",
        "    Run K-fold cross-validation for ONE random seed.\n",
        "\n",
        "    For each fold:\n",
        "        1. A fresh RandomForestRegressor is instantiated with `seed`.\n",
        "        2. The model is fit on the training split.\n",
        "        3. R² and MSE are recorded for BOTH train and test splits\n",
        "           so we can detect over-fitting fold-by-fold.\n",
        "\n",
        "    Parameters\n",
        "    ----------\n",
        "    X      : pd.DataFrame — full feature matrix (from Stage 1)\n",
        "    y      : pd.Series    — efficiency_score target\n",
        "    seed   : int          — controls both KFold shuffle AND the forest\n",
        "    config : dict         — CV_CONFIG defined above\n",
        "\n",
        "    Returns\n",
        "    -------\n",
        "    pd.DataFrame  — one row per fold, columns = RESULT_COLS\n",
        "    \"\"\"\n",
        "    kf = KFold(\n",
        "        n_splits=config[\"n_splits\"],\n",
        "        shuffle=True,\n",
        "        random_state=seed          # shuffle reproducibly for this seed\n",
        "    )\n",
        "\n",
        "    fold_records = []\n",
        "\n",
        "    for fold_idx, (train_idx, test_idx) in enumerate(kf.split(X), start=1):\n",
        "\n",
        "        # ── Slice this fold's data ────────────────────────────────────────────\n",
        "        X_train, X_test = X.iloc[train_idx], X.iloc[test_idx]\n",
        "        y_train, y_test = y.iloc[train_idx], y.iloc[test_idx]\n",
        "\n",
        "        # ── Train a fresh forest (seed controls both bootstrap & split) ───────\n",
        "        model = RandomForestRegressor(\n",
        "            n_estimators     = config[\"n_estimators\"],\n",
        "            min_samples_leaf = config[\"min_samples_leaf\"],\n",
        "            max_depth        = config[\"max_depth\"],\n",
        "            random_state     = seed,\n",
        "            n_jobs           = -1\n",
        "        )\n",
        "        model.fit(X_train, y_train)\n",
        "\n",
        "        # ── Evaluate on both splits ───────────────────────────────────────────\n",
        "        y_pred_train = model.predict(X_train)\n",
        "        y_pred_test  = model.predict(X_test)\n",
        "\n",
        "        fold_records.append({\n",
        "            \"seed\"     : seed,\n",
        "            \"fold\"     : fold_idx,\n",
        "            \"r2_train\" : r2_score(y_train, y_pred_train),\n",
        "            \"mse_train\": mean_squared_error(y_train, y_pred_train),\n",
        "            \"r2_test\"  : r2_score(y_test,  y_pred_test),\n",
        "            \"mse_test\" : mean_squared_error(y_test,  y_pred_test),\n",
        "        })\n",
        "\n",
        "    return pd.DataFrame(fold_records, columns=RESULT_COLS)\n"
      ],
