        "def predict_sgrna_efficiency(sgrna_df:        pd.DataFrame,\n",
        "                              model,\n",
        "                              feature_columns: list) -> pd.DataFrame:\n",
        "    \"\"\"\n",
        "    Predict cutting efficiency for every candidate sgRNA.\n",
        "\n",
        "    Uses the shared build_feature_matrix() from Stage 1 so that\n",
        "    feature extraction is byte-identical to training time.\n",
        "\n",
        "    Feature alignment\n",
        "    ──────────────────\n",
        "    After extraction, columns are reindexed to match feature_columns exactly:\n",
        "        • Missing columns (should never occur with valid 20-nt sequences)\n",
        "          are filled with 0 and flagged.\n",
        "        • Extra columns are silently dropped (e.g. if bio_penalty was added\n",
        "          at some point but is not part of the training feature set).\n",
        "\n",
        "    Parameters\n",
        "    ----------\n",
        "    sgrna_df        : pd.DataFrame  — output of generate_sgrnas()\n",
        "    model           : fitted RandomForestRegressor\n",
        "    feature_columns : list          — ordered feature names from training\n",
        "                                      (the feature_columns variable)\n",
        "\n",
        "    Returns\n",
        "    -------\n",
        "    pd.DataFrame  — input columns + predicted_efficiency + feature_rank,\n",
        "                    sorted by predicted_efficiency descending.\n",
        "    \"\"\"\n",
        "    if sgrna_df.empty:\n",
        "        print(\"[predict] No candidates to score.\")\n",
        "        return sgrna_df\n",
        "\n",
        "    print(f\"[predict] Extracting features for {len(sgrna_df):,} candidates …\")\n",
        "\n",
        "    # ── Feature extraction (calls the existing Stage 1 function) ─────────────\n",
        "    feat_df = build_feature_matrix(sgrna_df, seq_col=\"sgRNA_sequence\")\n",
        "\n",
        "    # ── Align to training feature order ──────────────────────────────────────\n",
        "    missing = [c for c in feature_columns if c not in feat_df.columns]\n",
        "    if missing:\n",
        "        print(f\"  ⚠ {len(missing)} missing feature(s) filled with 0: \"\n",
        "              f\"{missing[:5]}{'…' if len(missing) > 5 else ''}\")\n",
        "        for col in missing:\n",
        "            feat_df[col] = 0\n",
        "\n",
        "    X = feat_df[feature_columns]   # enforce identical column order\n",
        "\n",
        "    # ── Predict ───────────────────────────────────────────────────────────────\n",
        "    predictions = model.predict(X)\n",
        "    predictions = np.clip(predictions, 0.0, 1.0)   # safety clip to [0,1]\n",
        "\n",
        "    # ── Assemble output dataframe ─────────────────────────────────────────────\n",
        "    result = sgrna_df.copy().reset_index(drop=True)\n",
        "    result[\"predicted_efficiency\"] = predictions.round(4)\n",
        "    result = result.sort_values(\"predicted_efficiency\",\n",
        "                                ascending=False).reset_index(drop=True)\n",
        "    result[\"rank\"] = result.index + 1\n",
        "\n",
        "    print(f\"[predict] Predictions complete.\")\n",
        "    print(f\"          Efficiency range : \"\n",
        "          f\"[{predictions.min():.3f}, {predictions.max():.3f}]\")\n",
        "    print(f\"          Mean efficiency  : {predictions.mean():.3f}\\n\")\n",
        "    return result"
      ],
      "metadata": {
        "id": "k6HqUoFFcBBp"
