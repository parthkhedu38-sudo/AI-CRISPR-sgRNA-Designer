        "def run_all_approaches(\n",
        "        X: pd.DataFrame,\n",
        "        y: pd.Series,\n",
        "        penalties: pd.Series,\n",
        "        config: dict = CV_CONFIG,\n",
        "        alpha: float = 0.25,\n",
        "        beta:  float = 0.15,\n",
        ") -> dict:\n",
        "    \"\"\"\n",
        "    Train and evaluate four configurations in a fair comparison:\n",
        "\n",
        "        baseline    — raw y, no weights, no post-hoc\n",
        "        smoothed    — target-smoothed y (Approach 1)\n",
        "        weighted    — raw y + sample_weight (Approach 2)\n",
        "        posthoc     — raw y, no weights, post-hoc at inference (Approach 3)\n",
        "\n",
        "    Same CV config (seeds, folds, RF params) for all four.\n",
        "\n",
        "    Parameters\n",
        "    ----------\n",
        "    X         : pd.DataFrame — feature matrix (without penalty, without target)\n",
        "    y         : pd.Series    — raw efficiency_score\n",
        "    penalties : pd.Series    — bio_penalty\n",
        "    config    : dict\n",
        "    alpha     : float        — target smoothing blend strength\n",
        "    beta      : float        — post-hoc penalty scale\n",
        "\n",
        "    Returns\n",
        "    -------\n",
        "    dict  — label → pd.DataFrame of CV results\n",
        "    \"\"\"\n",
        "    sw      = compute_sample_weights(penalties)\n",
        "    y_sm    = apply_target_smoothing(y, penalties, alpha=alpha)\n",
        "    pen_arr = penalties.values\n",
        "\n",
        "    results = {}\n",
        "    results[\"baseline\"] = _cv_run(X, y,   config, \"baseline\")\n",
        "    results[\"smoothed\"] = _cv_run(X, y_sm, config, \"smoothed\")\n",
        "    results[\"weighted\"] = _cv_run(X, y,   config, \"weighted\",\n",
        "                                   sample_weights=sw)\n",
        "    results[\"posthoc\"]  = _cv_run(X, y,   config, \"posthoc\",\n",
        "                                   posthoc_penalties=pen_arr,\n",
        "                                   posthoc_beta=beta)\n",
        "    return results"
      ],
