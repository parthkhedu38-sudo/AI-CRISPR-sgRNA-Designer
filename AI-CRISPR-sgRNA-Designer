    {
      "cell_type": "code",
      "source": [
        "def build_ml_dataset(df: pd.DataFrame,\n",
        "                     seq_col: str = \"sgRNA_sequence\",\n",
        "                     target_col: str = \"efficiency_score\",\n",
        "                     keep_meta: bool = True) -> pd.DataFrame:\n",
        "    \"\"\"\n",
        "    Produce the final ML-ready dataframe by combining:\n",
        "        - (optional) metadata columns — gene, sgRNA_sequence\n",
        "        - extracted feature matrix\n",
        "        - efficiency_score target column\n",
        "\n",
        "    Column order:\n",
        "        [meta cols] | [20 feature cols] | efficiency_score\n",
        "\n",
        "    Parameters\n",
        "    ----------\n",
        "    df         : pd.DataFrame  — validated dataframe\n",
        "    seq_col    : str           — sequence column name\n",
        "    target_col : str           — target column name\n",
        "    keep_meta  : bool          — whether to retain gene + sequence columns\n",
        "\n",
        "    Returns\n",
        "    -------\n",
        "    pd.DataFrame  — ready for X / y split before model training\n",
        "    \"\"\"\n",
        "    feature_df = build_feature_matrix(df, seq_col=seq_col)\n",
        "\n",
        "    if keep_meta:\n",
        "        meta_cols = [\"gene\", seq_col]\n",
        "        available_meta = [c for c in meta_cols if c in df.columns]\n",
        "        meta_df = df[available_meta].reset_index(drop=True)\n",
        "        result = pd.concat([meta_df, feature_df], axis=1)\n",
        "    else:\n",
        "        result = feature_df.copy()\n",
        "\n",
        "    # Append target as the last column\n",
        "    result[target_col] = df[target_col].values\n",
        "\n",
        "    return result"
