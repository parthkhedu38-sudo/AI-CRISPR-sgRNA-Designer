        "def print_comparison_summary(base_results: pd.DataFrame,\n",
        "                              enh_results:  pd.DataFrame) -> pd.DataFrame:\n",
        "    \"\"\"\n",
        "    Print a side-by-side comparison table of mean ± std for both models.\n",
        "\n",
        "    Reports:\n",
        "        • Test R²   mean ± std\n",
        "        • Test MSE  mean ± std\n",
        "        • Overfitting gap Δ R²  (train − test)\n",
        "        • Absolute and relative improvement from positional encoding\n",
        "\n",
        "    Parameters\n",
        "    ----------\n",
        "    base_results : pd.DataFrame — CV output for baseline\n",
        "    enh_results  : pd.DataFrame — CV output for enhanced\n",
        "\n",
        "    Returns\n",
        "    -------\n",
        "    pd.DataFrame  — comparison summary suitable for display or export\n",
        "    \"\"\"\n",
        "    def _stats(df):\n",
        "        return {\n",
        "            \"r2_test_mean\" : df[\"r2_test\"].mean(),\n",
        "            \"r2_test_std\"  : df[\"r2_test\"].std(),\n",
        "            \"mse_test_mean\": df[\"mse_test\"].mean(),\n",
        "            \"mse_test_std\" : df[\"mse_test\"].std(),\n",
        "            \"overfit_gap\"  : (df[\"r2_train\"] - df[\"r2_test\"]).mean(),\n",
        "        }\n",
        "\n",
        "    bs = _stats(base_results)\n",
        "    es = _stats(enh_results)\n",
        "\n",
        "    delta_r2  = es[\"r2_test_mean\"]  - bs[\"r2_test_mean\"]\n",
        "    delta_mse = es[\"mse_test_mean\"] - bs[\"mse_test_mean\"]\n",
        "    rel_r2    = delta_r2  / abs(bs[\"r2_test_mean\"])  * 100 if bs[\"r2_test_mean\"]  else 0\n",
        "    rel_mse   = delta_mse / abs(bs[\"mse_test_mean\"]) * 100 if bs[\"mse_test_mean\"] else 0\n",
        "\n",
        "    W = 70\n",
        "    print(\"=\" * W)\n",
        "    print(\"BEFORE vs AFTER — POSITIONAL ONE-HOT ENCODING\")\n",
        "    print(\"=\" * W)\n",
        "    print(f\"  {'Metric':<28} {'Baseline':>16} {'Enhanced':>16}\")\n",
        "    print(f\"  {'-'*(W-2)}\")\n",
        "    print(f\"  {'Test R²  (mean ± std)':<28} \"\n",
        "          f\"  {bs['r2_test_mean']:>6.4f} ± {bs['r2_test_std']:.4f}\"\n",
        "          f\"  {es['r2_test_mean']:>6.4f} ± {es['r2_test_std']:.4f}\")\n",
        "    print(f\"  {'Test MSE (mean ± std)':<28} \"\n",
        "          f\"  {bs['mse_test_mean']:>6.6f} ± {bs['mse_test_std']:.6f}\"\n",
        "          f\"  {es['mse_test_mean']:>6.6f} ± {es['mse_test_std']:.6f}\")\n",
        "    print(f\"  {'Overfitting gap Δ R²':<28} \"\n",
        "          f\"  {bs['overfit_gap']:>16.4f}\"\n",
        "          f\"  {es['overfit_gap']:>16.4f}\")\n",
        "    print(f\"  {'-'*(W-2)}\")\n",
        "    print(f\"  {'Δ Test R²  (enh − base)':<28}  {delta_r2:>+.4f}  \"\n",
        "          f\"({'↑' if delta_r2  > 0 else '↓'} {abs(rel_r2):.1f}%)\")\n",
        "    print(f\"  {'Δ Test MSE (enh − base)':<28}  {delta_mse:>+.6f}  \"\n",
        "          f\"({'↓ better' if delta_mse < 0 else '↑ worse'}  {abs(rel_mse):.1f}%)\")\n",
        "    print(\"=\" * W)\n",
        "    print()\n",
        "\n",
        "    summary_df = pd.DataFrame([\n",
        "        {\"model\": \"baseline\", **bs},\n",
        "        {\"model\": \"enhanced\", **es},\n",
        "    ])\n",
        "    return summary_df"
