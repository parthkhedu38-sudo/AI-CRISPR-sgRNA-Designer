        "def normalise_to_unit_interval(scores: pd.Series) -> pd.Series:\n",
        "    \"\"\"\n",
        "    Min-max normalise the mean z-scores to [0, 1].\n",
        "\n",
        "    This step is required for compatibility with the ML pipeline, which\n",
        "    expects efficiency_score ∈ [0, 1] (consistent with internal training data,\n",
        "    biological penalty thresholds, and SHAP interpretation).\n",
        "\n",
        "    Formula:  y_norm = (y − y_min) / (y_max − y_min)\n",
        "\n",
        "    Parameters\n",
        "    ----------\n",
        "    scores : pd.Series — mean standardised scores (arbitrary scale)\n",
        "\n",
        "    Returns\n",
        "    -------\n",
        "    pd.Series — normalised scores in [0, 1]\n",
        "    \"\"\"\n",
        "    lo, hi    = scores.min(), scores.max()\n",
        "    normalised = (scores - lo) / (hi - lo)\n",
        "    print(f\"[normalise] Raw mean score range : [{lo:.4f}, {hi:.4f}]\")\n",
        "    print(f\"[normalise] After normalisation  : [{normalised.min():.4f}, \"\n",
        "          f\"{normalised.max():.4f}]\\n\")\n",
        "    return normalised"
      ],
      "metadata": {
        "id": "hMhNjQrl6OCV"
      },
