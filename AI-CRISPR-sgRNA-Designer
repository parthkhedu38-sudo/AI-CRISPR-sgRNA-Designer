        "def generate_sgrnas(sequence: str) -> pd.DataFrame:\n",
        "    \"\"\"\n",
        "    Scan a DNA sequence for all valid Cas9 sgRNA candidates.\n",
        "\n",
        "    Strategy\n",
        "    ─────────\n",
        "    SpCas9 requires a 5'-NGG-3' PAM immediately 3' of the 20-nt protospacer.\n",
        "    We scan both strands:\n",
        "\n",
        "        Forward strand:  [20-nt guide][NGG]\n",
        "        Reverse strand:  [CCN][20-nt guide]  (reverse-complement view)\n",
        "\n",
        "    For the reverse strand we take the reverse complement so that the\n",
        "    returned sequence is always reported in the 5'→3' guide orientation\n",
        "    (the form used for ordering oligos and for feature extraction).\n",
        "\n",
        "    Positions are reported as the 0-based start of the 20-nt protospacer\n",
        "    on the FORWARD strand in both cases, consistent with standard\n",
        "    genome-browser coordinates.\n",
        "\n",
        "    Parameters\n",
        "    ----------\n",
        "    sequence : str\n",
        "        Input DNA sequence (any length, upper or lower case, may contain\n",
        "        N but guides containing N are filtered out).\n",
        "\n",
        "    Returns\n",
        "    -------\n",
        "    pd.DataFrame with columns:\n",
        "        sgRNA_sequence  — 20-nt guide in 5'→3' orientation (uppercase)\n",
        "        pam             — 3-nt PAM sequence (NGG on forward, CCN on reverse)\n",
        "        position        — 0-based start of protospacer on forward strand\n",
        "        strand          — '+' or '-'\n",
        "        context_30mer   — 4-nt upstream + guide + PAM (30 nt total context)\n",
        "    \"\"\"\n",
        "    sequence = sequence.upper().strip()\n",
        "    n        = len(sequence)\n",
        "    records  = []\n",
        "\n",
        "    print(f\"[scan] Input sequence length : {n:,} bp\")\n",
        "\n",
        "    # ── Forward strand: find [20-nt][NGG] ─────────────────────────────────────\n",
        "    # Use regex with lookahead so overlapping hits are all captured\n",
        "    for match in re.finditer(r'(?=([ATGCN]{20}[ATGC]GG))', sequence):\n",
        "        hit   = match.group(1)          # 23-nt window\n",
        "        guide = hit[:20]\n",
        "        pam   = hit[20:]\n",
        "        pos   = match.start()\n",
        "\n",
        "        if \"N\" in guide:                # skip ambiguous guides\n",
        "            continue\n",
        "\n",
        "        context_start = max(0, pos - 4)\n",
        "        context       = sequence[context_start: pos + 23]\n",
        "\n",
        "        records.append({\n",
        "            \"sgRNA_sequence\": guide,\n",
        "            \"pam\"           : pam,\n",
        "            \"position\"      : pos,\n",
        "            \"strand\"        : \"+\",\n",
        "            \"context_30mer\" : context,\n",
        "        })\n",
        "\n",
        "    # ── Reverse strand: find CCN on forward = NGG on reverse ──────────────────\n",
        "    # Pattern on forward strand: [CCN][20-nt]\n",
        "    # The guide on the reverse strand is the rev-comp of the 20-nt region.\n",
        "    _comp = str.maketrans(\"ATGCN\", \"TACGN\")\n",
        "\n",
        "    def revcomp(s: str) -> str:\n",
        "        return s.translate(_comp)[::-1]\n",
        "\n",
        "    for match in re.finditer(r'(?=(CC[ATGCN][ATGCN]{20}))', sequence):\n",
        "        hit     = match.group(1)        # 23-nt window (CCN + 20-nt)\n",
        "        pam_fwd = hit[:3]               # CCN on forward = NGG on reverse\n",
        "        guide_fwd = hit[3:]             # 20-nt region (forward coords)\n",
        "        guide   = revcomp(guide_fwd)    # guide in 5'→3' orientation\n",
        "        pam     = revcomp(pam_fwd)      # NGG\n",
        "\n",
        "        # 0-based start of the protospacer on the forward strand\n",
        "        pos = match.start() + 3\n",
        "\n",
        "        if \"N\" in guide:\n",
        "            continue\n",
        "\n",
        "        context_start = max(0, match.start() - 1)\n",
        "        context       = revcomp(sequence[context_start: match.start() + 23])\n",
        "\n",
        "        records.append({\n",
        "            \"sgRNA_sequence\": guide,\n",
        "            \"pam\"           : pam,\n",
        "            \"position\"      : pos,\n",
        "            \"strand\"        : \"-\",\n",
        "            \"context_30mer\" : context,\n",
        "        })\n",
        "\n",
        "    df = pd.DataFrame(records).drop_duplicates(\n",
        "        subset=[\"sgRNA_sequence\", \"position\", \"strand\"]\n",
        "    ).reset_index(drop=True)\n",
        "\n",
        "    n_fwd = (df[\"strand\"] == \"+\").sum()\n",
        "    n_rev = (df[\"strand\"] == \"-\").sum()\n",
        "    print(f\"[scan] Candidates found      : {len(df):,}  \"\n",
        "          f\"(+strand: {n_fwd}, −strand: {n_rev})\\n\")\n",
        "    return df"
      ],
