        "def explain_single_guide(explainer: shap.TreeExplainer,\n",
        "                          X_explained: pd.DataFrame,\n",
        "                          imp_df: pd.DataFrame,\n",
        "                          guide_index: int = 0,\n",
        "                          top_n: int = 12) -> None:\n",
        "    \"\"\"\n",
        "    Produce a waterfall-style bar chart explaining ONE guide's prediction.\n",
        "\n",
        "    A waterfall chart shows how each feature pushed the prediction for\n",
        "    guide `guide_index` above or below the dataset average (base value).\n",
        "\n",
        "    This is the most biologically actionable output: given a specific\n",
        "    guide sequence, it answers \"why does the model think this guide will\n",
        "    work well (or poorly)?\"\n",
        "\n",
        "    Parameters\n",
        "    ----------\n",
        "    explainer    : shap.TreeExplainer\n",
        "    X_explained  : pd.DataFrame  — the explained sample (indexed from 0)\n",
        "    imp_df       : pd.DataFrame  — global importance table (for feature types)\n",
        "    guide_index  : int           — which sample to explain\n",
        "    top_n        : int           — how many features to show in the waterfall\n",
        "    \"\"\"\n",
        "    shap_single = explainer.shap_values(\n",
        "        X_explained.iloc[[guide_index]]\n",
        "    )[0]   # shape: (n_features,)\n",
        "\n",
        "    base_val = float(explainer.expected_value)\n",
        "    pred_val = float(base_val + shap_single.sum())\n",
        "\n",
        "    # Sort by |SHAP| and take top_n\n",
        "    sv_series = pd.Series(shap_single, index=X_explained.columns)\n",
        "    top_sv    = sv_series.abs().nlargest(top_n).index\n",
        "    sv_top    = sv_series[top_sv].sort_values()\n",
        "\n",
        "    # ── Reconstruct the guide sequence from one-hot columns ──────────────────\n",
        "    pos_cols = [c for c in X_explained.columns if c.startswith(\"pos\")]\n",
        "    guide_seq = \"\"\n",
        "    for pos in range(1, 21):\n",
        "        for base in [\"A\",\"T\",\"G\",\"C\"]:\n",
        "            col = f\"pos{pos:02d}_{base}\"\n",
        "            if col in X_explained.columns and X_explained.iloc[guide_index][col] == 1:\n",
        "                guide_seq += base\n",
        "                break\n",
        "    if len(guide_seq) < 20:\n",
        "        guide_seq = \"sequence unavailable\"\n",
        "\n",
        "    fig, ax = plt.subplots(figsize=(10, 6))\n",
        "    fig.patch.set_facecolor(\"#F8FAFC\")\n",
        "    ax.set_facecolor(\"#F8FAFC\")\n",
        "\n",
        "    colors = [\"#EF4444\" if v > 0 else \"#2563EB\" for v in sv_top.values]\n",
        "    bars = ax.barh(range(len(sv_top)), sv_top.values, color=colors,\n",
        "                   edgecolor=\"none\", height=0.65)\n",
        "\n",
        "    for bar, val in zip(bars, sv_top.values):\n",
        "        x_pos = val + (sv_top.abs().max() * 0.015) * np.sign(val)\n",
        "        ax.text(x_pos, bar.get_y() + bar.get_height() / 2,\n",
        "                f\"{val:+.5f}\", va=\"center\", ha=\"left\" if val > 0 else \"right\",\n",
        "                fontsize=8, color=\"#1E293B\")\n",
        "\n",
        "    ax.set_yticks(range(len(sv_top)))\n",
        "    ax.set_yticklabels(sv_top.index, fontsize=8.5)\n",
        "    ax.axvline(0, color=\"#64748B\", linewidth=1.0)\n",
        "    ax.set_xlabel(\"SHAP value  (red = pushes efficiency ↑, blue = pushes ↓)\",\n",
        "                  fontsize=9)\n",
        "    ax.set_title(\n",
        "        f\"Single-Guide Waterfall — Guide #{guide_index}\\n\"\n",
        "        f\"Sequence: {guide_seq}   |   \"\n",
        "        f\"Base value: {base_val:.3f}   Prediction: {pred_val:.3f}\",\n",
        "        fontsize=10, fontweight=\"bold\"\n",
        "    )\n",
        "    ax.grid(True, axis=\"x\", linestyle=\"--\", linewidth=0.4, alpha=0.5)\n",
        "\n",
        "    plt.tight_layout()\n",
        "    plt.savefig(f\"/tmp/crispr_shap_guide_{guide_index}.png\",\n",
        "                dpi=150, bbox_inches=\"tight\")\n",
        "    plt.show()\n",
        "    print(f\"[waterfall] Guide #{guide_index}: \"\n",
        "          f\"base={base_val:.3f}, predicted={pred_val:.3f}\\n\")"
      ],
