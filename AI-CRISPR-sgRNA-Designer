        "        train → SHAP values → importance table → position rollup\n",
        "        → visualise → waterfall → biological report\n",
        "\n",
        "    Parameters\n",
        "    ----------\n",
        "    enhanced_dataset : pd.DataFrame\n",
        "        Stage 4 output: 100-feature fused matrix + efficiency_score.\n",
        "    target_col       : str\n",
        "    drop_cols        : tuple  — metadata columns to discard\n",
        "    sample_limit     : int    — max samples passed to SHAP (Colab safety)\n",
        "    guide_to_explain : int    — index of guide for waterfall plot\n",
        "\n",
        "    Returns\n",
