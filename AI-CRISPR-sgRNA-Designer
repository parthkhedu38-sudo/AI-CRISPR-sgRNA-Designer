        "def run_sgrna_designer(sequence:        str,\n",
        "                        model,\n",
        "                        feature_columns: list,\n",
        "                        top_n:           int   = 10,\n",
        "                        min_efficiency:  float = 0.0,\n",
        "                        both_strands:    bool  = True,\n",
        "                        export_csv:      bool  = True) -> pd.DataFrame:\n",
        "    best_model = results_on_doench['model']\n",
        "\n",
        "    \"\"\"\n",
        "    Full end-to-end sgRNA design with display, visualisation, and export.\n",
        "\n",
        "    This is the single function to call from a Colab cell.\n",
        "\n",
        "    Parameters\n",
        "    ----------\n",
        "    sequence        : str   — target DNA sequence\n",
        "    model           : fitted RandomForestRegressor (best_model)\n",
        "    feature_columns : list  — training feature column order\n",
        "    top_n           : int   — number of top guides to return\n",
        "    min_efficiency  : float — minimum efficiency filter\n",
        "    both_strands    : bool  — scan both strands\n",
        "    export_csv      : bool  — save results to CSV\n",
        "\n",
        "    Returns\n",
        "    -------\n",
        "    pd.DataFrame — final top_n sgRNA candidates with all annotations\n",
        "    \"\"\"\n",
        "    # ── Step 1: Generate + rank all candidates ────────────────────────────────\n",
        "    all_candidates = generate_sgrnas(sequence)\n",
        "    if all_candidates.empty:\n",
        "        print(\"✗ No PAM sites found. Check that your sequence contains NGG motifs.\")\n",
        "        return pd.DataFrame()\n",
        "\n",
        "    if not both_strands:\n",
        "        all_candidates = all_candidates[\n",
        "            all_candidates[\"strand\"] == \"+\"\n",
        "        ].reset_index(drop=True)\n",
        "\n",
        "    all_ranked = predict_sgrna_efficiency(all_candidates, model, feature_columns)\n",
        "\n",
        "    # ── Step 2: Filter + select top N ────────────────────────────────────────\n",
        "    top_df = design_sgrnas(sequence, model, feature_columns,\n",
        "                            top_n=top_n,\n",
        "                            min_efficiency=min_efficiency,\n",
        "                            both_strands=both_strands)\n",
        "    if top_df.empty:\n",
        "        return pd.DataFrame()\n",
        "\n",
        "    # ── Step 3: Attach off-target risk flags ─────────────────────────────────\n",
        "    top_df = flag_off_target_risk(top_df)\n",
        "\n",
        "    # ── Step 4: Display results table ────────────────────────────────────────\n",
        "    print_design_results(top_df)\n",
        "\n",
        "    # ── Step 5: Visualise ────────────────────────────────────────────────────\n",
        "    plot_design_results(top_df, all_ranked, sequence)\n",
        "\n",
        "    # ── Step 6: Export ───────────────────────────────────────────────────────\n",
        "    if export_csv:\n",
        "        export_results(top_df)\n",
        "\n",
        "    return top_df"
      ],
