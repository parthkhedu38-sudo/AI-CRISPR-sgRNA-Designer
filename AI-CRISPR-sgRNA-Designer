        "def prepare_xy(df: pd.DataFrame,\n",
        "               target_col: str = \"efficiency_score\",\n",
        "               drop_cols: tuple = (\"gene\", \"sgRNA_sequence\")) -> tuple:\n",
        "    \"\"\"\n",
        "    Separate the feature matrix X from the target vector y.\n",
        "\n",
        "    Columns listed in `drop_cols` and the target itself are excluded from X.\n",
        "    All remaining columns are treated as numeric features.\n",
        "\n",
        "    Parameters\n",
        "    ----------\n",
        "    df         : pd.DataFrame  — ML-ready dataset from Stage 1\n",
        "    target_col : str           — name of the target column\n",
        "    drop_cols  : tuple         — metadata columns to exclude from features\n",
        "\n",
        "    Returns\n",
        "    -------\n",
        "    X : pd.DataFrame  — feature matrix  (n_samples × n_features)\n",
        "    y : pd.Series     — target vector   (n_samples,)\n",
        "    \"\"\"\n",
        "    cols_to_drop = [c for c in drop_cols if c in df.columns] + [target_col]\n",
        "    X = df.drop(columns=cols_to_drop)\n",
        "    y = df[target_col]\n",
        "\n",
        "    print(f\"[prepare] X shape : {X.shape}\")\n",
        "    print(f\"[prepare] y shape : {y.shape}\")\n",
        "    print(f\"[prepare] Features: {list(X.columns)}\\n\")\n",
        "    return X, y"
      ],
      "execution_count": null,
      "outputs": []
    },
