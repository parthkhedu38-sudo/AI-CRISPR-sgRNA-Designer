        "def evaluate_model(model: RandomForestRegressor,\n",
        "                   X_train: pd.DataFrame,\n",
        "                   X_test: pd.DataFrame,\n",
        "                   y_train: pd.Series,\n",
        "                   y_test: pd.Series) -> dict:\n",
        "    \"\"\"\n",
        "    Compute R² and MSE on both the training and held-out test sets.\n",
        "\n",
        "    Reporting both splits lets us detect overfitting:\n",
        "        • Train R² ≫ Test R²  → model is overfitting\n",
        "        • Train R² ≈ Test R²  → good generalisation\n",
        "\n",
        "    Parameters\n",
        "    ----------\n",
        "    model   : fitted RandomForestRegressor\n",
        "    X_train : pd.DataFrame — training features\n",
        "    X_test  : pd.DataFrame — test features\n",
        "    y_train : pd.Series    — training targets\n",
        "    y_test  : pd.Series    — test targets\n",
        "\n",
        "    Returns\n",
        "    -------\n",
        "    dict  — metrics keyed by split name\n",
        "    \"\"\"\n",
        "    splits = {\n",
        "        \"Train\": (X_train, y_train),\n",
        "        \"Test\" : (X_test,  y_test),\n",
        "    }\n",
        "\n",
        "    metrics = {}\n",
        "    print(\"=\" * 42)\n",
        "    print(f\"{'Split':<8} {'R²':>10} {'MSE':>14} {'RMSE':>14}\")\n",
        "    print(\"-\" * 42)\n",
        "\n",
        "    for name, (X_split, y_split) in splits.items():\n",
        "        y_pred = model.predict(X_split)\n",
        "        r2  = r2_score(y_split, y_pred)\n",
        "        mse = mean_squared_error(y_split, y_pred)\n",
        "        rmse = np.sqrt(mse)\n",
        "        metrics[name] = {\"r2\": r2, \"mse\": mse, \"rmse\": rmse,\n",
        "                         \"y_true\": y_split, \"y_pred\": y_pred}\n",
        "        print(f\"{name:<8} {r2:>10.4f} {mse:>14.6f} {rmse:>14.6f}\")\n",
        "\n",
        "    print(\"=\" * 42)\n",
        "    print()\n",
        "    return metrics\n",
        "\n"
      ],
      "execution_count": null,
      "outputs": []
    },
