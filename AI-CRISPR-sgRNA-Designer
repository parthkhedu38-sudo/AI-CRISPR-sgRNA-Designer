        "def apply_posthoc_penalty(y_pred: np.ndarray,\n",
        "                           penalties: np.ndarray,\n",
        "                           beta: float = 0.15) -> np.ndarray:\n",
        "    \"\"\"\n",
        "    Subtract a scaled penalty from raw forest predictions at inference time.\n",
        "\n",
        "    Formula:\n",
        "        ŷ_adj[i]  =  clip( ŷ_raw[i]  −  β × penalty[i],  0,  1 )\n",
        "\n",
        "    This does NOT change the trained model — it adjusts outputs for\n",
        "    biologically implausible guides so they score lower in candidate ranking.\n",
        "\n",
        "    Use case: a guide passes the trained model's threshold but has\n",
        "    TTTTTT at position 3; the post-hoc penalty flags it as risky.\n",
        "\n",
        "    Parameters\n",
        "    ----------\n",
        "    y_pred    : np.ndarray — raw model predictions\n",
        "    penalties : np.ndarray — bio_penalty for the same samples\n",
        "    beta      : float      — penalty scale ∈ (0, 1), default 0.15\n",
        "\n",
        "    Returns\n",
        "    -------\n",
        "    np.ndarray  — adjusted predictions clipped to [0, 1]\n",
        "    \"\"\"\n",
        "    y_adj = np.clip(y_pred - beta * penalties, 0.0, 1.0)\n",
        "    print(f\"[posthoc] Post-hoc penalty applied  (β={beta}).\")\n",
        "    print(f\"          Mean shift : {np.abs(y_adj - y_pred).mean():.5f}\\n\")\n",
        "    return y_adj"
      ],
      "metadata": {
        "id": "JdmAEDtx7Y6x"
      },
      "execution_count": null,
      "outputs": []
