    {
      "cell_type": "code",
      "source": [
        "def extract_features(seq: str) -> dict:\n",
        "    \"\"\"\n",
        "    Apply all feature extraction functions to a single sequence and return\n",
        "    a flat dictionary of feature name → value.\n",
        "\n",
        "    Feature groups produced:\n",
        "        • gc_content          (1 feature)\n",
        "        • seed_gc_content     (1 feature)\n",
        "        • longest_homopolymer (1 feature)\n",
        "        • sequence_entropy    (1 feature)\n",
        "        • dinucleotide_*      (16 features)\n",
        "        ─────────────────────────────────\n",
        "        Total: 20 features\n",
        "\n",
        "    Parameters\n",
        "    ----------\n",
        "    seq : str  — validated 20-nt sequence\n",
        "\n",
        "    Returns\n",
        "    -------\n",
        "    dict  — feature_name → numeric value\n",
        "    \"\"\"\n",
        "    features = {}\n",
        "\n",
        "    # Scalar features\n",
        "    features[\"gc_content\"]          = gc_content(seq)\n",
        "    features[\"seed_gc_content\"]     = seed_gc_content(seq)\n",
        "    features[\"longest_homopolymer\"] = longest_homopolymer(seq)\n",
        "    features[\"sequence_entropy\"]    = sequence_entropy(seq)\n",
        "\n",
        "    # Dinucleotide features (16 columns, prefixed for clarity)\n",
        "    di_freqs = dinucleotide_frequencies(seq)\n",
        "    for dinuc, freq in di_freqs.items():\n",
        "        features[f\"dinuc_{dinuc}\"] = freq\n",
        "\n",
        "    return features\n",
        "\n",
        "\n",
        "def build_feature_matrix(df: pd.DataFrame,\n",
        "                          seq_col: str = \"sgRNA_sequence\") -> pd.DataFrame:\n",
        "    \"\"\"\n",
        "    Apply extract_features() to every sequence and return a feature DataFrame.\n",
        "\n",
        "    Each row corresponds to one sgRNA; columns are individual features.\n",
        "\n",
        "    Parameters\n",
        "    ----------\n",
        "    df      : pd.DataFrame  — validated dataframe\n",
        "    seq_col : str           — column containing the sequences\n",
        "\n",
        "    Returns\n",
        "    -------\n",
        "    pd.DataFrame  — shape (n_sequences, n_features)\n",
        "    \"\"\"\n",
        "    print(\"[features] Extracting features …\")\n",
        "    feature_records = df[seq_col].apply(extract_features)\n",
        "    feature_df = pd.DataFrame(list(feature_records))\n",
        "    print(f\"[features] Feature matrix shape: {feature_df.shape}\")\n",
        "    print(f\"[features] Features: {list(feature_df.columns)}\\n\")\n",
        "    return feature_df"
      ],
