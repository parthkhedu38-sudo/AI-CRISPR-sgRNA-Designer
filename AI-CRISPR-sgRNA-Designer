        "def gc_content(seq: str) -> float:\n",
        "    \"\"\"\n",
        "    Compute GC content of the full 20-nt sequence.\n",
        "\n",
        "    GC content = (count(G) + count(C)) / length\n",
        "\n",
        "    Parameters\n",
        "    ----------\n",
        "    seq : str  — validated 20-nt sequence\n",
        "\n",
        "    Returns\n",
        "    -------\n",
        "    float in [0, 1]\n",
        "    \"\"\"\n",
        "    return (seq.count(\"G\") + seq.count(\"C\")) / len(seq)"
      ],
