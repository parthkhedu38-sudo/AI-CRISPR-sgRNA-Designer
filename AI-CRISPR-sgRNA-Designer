        "\n",
        "    # ── Panel A: Predicted vs Actual ─────────────────────────────────────\n",
        "    ax1 = fig.add_subplot(gs[0])\n",
        "    ax1.set_facecolor(\"#F8FAFC\")\n",
        "\n",
        "    test_m  = metrics[\"Test\"]\n",
        "    y_true  = test_m[\"y_true\"]\n",
        "    y_pred  = test_m[\"y_pred\"]\n",
        "\n",
