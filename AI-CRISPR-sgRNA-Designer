        "def assemble_dataset(df_raw:      pd.DataFrame,\n",
        "                      seq_col:    str  = SEQ_COL,\n",
        "                      target_col: str  = TARGET_COL,\n",
        "                      score_cols: list = SCORE_COLS) -> pd.DataFrame:\n",
        "    \"\"\"\n",
        "    Full preprocessing chain:\n",
        "        standardise → mean → normalise → validate → assemble → drop NaN\n",
        "\n",
        "    Output dataframe has exactly two columns used by the feature pipeline:\n",
        "        sgRNA_sequence  — 20-nt uppercase sequence\n",
        "        efficiency_score — float in [0, 1]\n",
        "\n",
        "    Parameters\n",
        "    ----------\n",
        "    df_raw     : pd.DataFrame — raw data from load_raw()\n",
        "    seq_col    : str\n",
        "    target_col : str\n",
        "    score_cols : list\n",
        "\n",
        "    Returns\n",
        "    -------\n",
        "    pd.DataFrame — clean, pipeline-ready dataset\n",
        "    \"\"\"\n",
        "    # Step 1: Standardise each assay column\n",
        "    df_std = standardise_scores(df_raw, score_cols)\n",
        "\n",
        "    # Step 2: Row-wise nanmean across standardised scores\n",
        "    mean_scores = compute_mean_score(df_std, score_cols)\n",
        "\n",
        "    # Step 3: Normalise to [0, 1]\n",
        "    norm_scores = normalise_to_unit_interval(mean_scores)\n",
        "\n",
        "    # Step 4: Build intermediate dataframe\n",
        "    df_work = pd.DataFrame({\n",
        "        SEQ_COL   : df_raw[seq_col].str.upper().str.strip(),\n",
        "        target_col: norm_scores.round(6),\n",
        "    })\n",
        "\n",
        "    # Step 5: Validate sequences (pipeline rule: 20 nt, ATGC only)\n",
        "    df_work = validate_sequences(df_work, seq_col=SEQ_COL)\n",
        "\n",
        "    # Step 6: Drop rows where efficiency_score is NaN\n",
        "    #         (shouldn't occur given nanmean + no all-null rows, but safety check)\n",
        "    before = len(df_work)\n",
        "    df_work = df_work.dropna(subset=[target_col]).reset_index(drop=True)\n",
        "    after  = len(df_work)\n",
        "    if before - after:\n",
        "        print(f\"[dropna] Dropped {before - after} rows with missing scores.\")\n",
        "\n",
        "    # Step 7: Rename sequence column to match pipeline expectation\n",
        "    df_work = df_work.rename(columns={SEQ_COL: \"sgRNA_sequence\"})\n",
        "\n",
        "    return df_work"
      ],
