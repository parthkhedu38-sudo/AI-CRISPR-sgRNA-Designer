        "    \"n_estimators\"   : 200,\n",
        "    \"min_samples_leaf\": 2,\n",
        "    \"max_depth\"      : None,\n",
        "}\n",
        "\n",
        "\n",
        "def _run_cv(X: pd.DataFrame,\n",
        "            y: pd.Series,\n",
        "            config: dict,\n",
        "            label: str) -> pd.DataFrame:\n",
        "    \"\"\"\n",
        "    Internal helper: run K-fold CV × multiple seeds and return a results table.\n",
        "\n",
        "    Records R² and MSE for both train and test splits so overfitting is\n",
        "    visible at the fold level, not just in aggregate.\n",
        "\n",
        "    Parameters\n",
        "    ----------\n",
        "    X      : pd.DataFrame — feature matrix\n",
        "    y      : pd.Series    — target\n",
        "    config : dict         — CV_CONFIG\n",
        "    label  : str          — 'baseline' or 'enhanced' (stored in results)\n",
        "\n",
        "    Returns\n",
        "    -------\n",
        "    pd.DataFrame  — columns: label, seed, fold, r2_train, mse_train,\n",
        "                                                 r2_test,  mse_test\n",
        "    \"\"\"\n",
        "    records = []\n",
        "    total   = len(config[\"seeds\"]) * config[\"n_splits\"]\n",
        "    done    = 0\n",
        "\n",
        "    print(f\"[cv:{label}] {len(config['seeds'])} seeds × \"\n",
        "          f\"{config['n_splits']} folds = {total} fits …\")\n",
        "\n",
        "    for seed in config[\"seeds\"]:\n",
        "        kf = KFold(n_splits=config[\"n_splits\"], shuffle=True, random_state=seed)\n",
        "\n",
        "        for fold_idx, (tr_idx, te_idx) in enumerate(kf.split(X), start=1):\n",
        "            X_tr, X_te = X.iloc[tr_idx], X.iloc[te_idx]\n",
        "            y_tr, y_te = y.iloc[tr_idx], y.iloc[te_idx]\n",
        "\n",
        "            model = RandomForestRegressor(\n",
        "                n_estimators     = config[\"n_estimators\"],\n",
        "                min_samples_leaf = config[\"min_samples_leaf\"],\n",
        "                max_depth        = config[\"max_depth\"],\n",
        "                random_state     = seed,\n",
        "                n_jobs           = -1\n",
        "            )\n",
        "            model.fit(X_tr, y_tr)\n",
        "\n",
        "            records.append({\n",
        "                \"label\"    : label,\n",
        "                \"seed\"     : seed,\n",
        "                \"fold\"     : fold_idx,\n",
        "                \"r2_train\" : r2_score(y_tr, model.predict(X_tr)),\n",
        "                \"mse_train\": mean_squared_error(y_tr, model.predict(X_tr)),\n",
        "                \"r2_test\"  : r2_score(y_te, model.predict(X_te)),\n",
        "                \"mse_test\" : mean_squared_error(y_te, model.predict(X_te)),\n",
        "            })\n",
        "            done += 1\n",
        "\n",
        "        seed_rows = [r for r in records if r[\"seed\"] == seed\n",
        "                                        and r[\"label\"] == label]\n",
        "        mean_r2 = np.mean([r[\"r2_test\"] for r in seed_rows])\n",
        "        print(f\"  seed={seed:>3d}  mean test R²={mean_r2:.4f}  \"\n",
        "              f\"[{done}/{total}]\")\n",
        "\n",
        "    df = pd.DataFrame(records)\n",
        "    print(f\"[cv:{label}] Done.\\n\")\n",
        "    return df"
      ],
