    {
      "cell_type": "code",
      "source": [
        "def longest_homopolymer(seq: str) -> int:\n",
        "    \"\"\"\n",
        "    Compute the length of the longest run of a single repeated nucleotide.\n",
        "\n",
        "    Long homopolymer runs (e.g. AAAA) can impair guide RNA secondary structure\n",
        "    and reduce editing efficiency.\n",
        "\n",
        "    Parameters\n",
        "    ----------\n",
        "    seq : str  — validated 20-nt sequence\n",
        "\n",
        "    Returns\n",
        "    -------\n",
        "    int  — length of the longest homopolymer run (minimum 1)\n",
        "    \"\"\"\n",
        "    if not seq:\n",
        "        return 0\n",
        "    max_run = 1\n",
        "    current_run = 1\n",
        "    for i in range(1, len(seq)):\n",
        "        if seq[i] == seq[i - 1]:\n",
        "            current_run += 1\n",
        "            max_run = max(max_run, current_run)\n",
        "        else:\n",
        "            current_run = 1\n",
        "    return max_run\n"
      ],
      "metadata": {
        "id": "DmbP_wW02XGf"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "def sequence_entropy(seq: str) -> float:\n",
        "    \"\"\"\n",
        "    Compute the Shannon entropy of the nucleotide composition.\n",
        "\n",
        "    H = -∑ p(b) * log2(p(b))  for each nucleotide base b ∈ {A, T, G, C}\n",
        "\n",
        "    Higher entropy → more compositional complexity.\n",
        "    Perfectly uniform sequence (0.25 each) gives H ≈ 2.0 bits.\n",
        "\n",
        "    Parameters\n",
        "    ----------\n",
        "    seq : str  — validated 20-nt sequence\n",
        "\n",
        "    Returns\n",
        "    -------\n",
        "    float  — Shannon entropy in bits (range: 0 – 2.0)\n",
        "    \"\"\"\n",
        "    counts = Counter(seq)\n",
        "    length = len(seq)\n",
        "    entropy = 0.0\n",
        "    for base in \"ATGC\":\n",
        "        p = counts.get(base, 0) / length\n",
        "        if p > 0:\n",
        "            entropy -= p * math.log2(p)\n",
        "    return entropy\n",
        "\n"
      ],
      "metadata": {
        "id": "UYJeUDRY2cEW"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "ALL_DINUCLEOTIDES = [\n",
        "    a + b for a in \"ATGC\" for b in \"ATGC\"\n",
        "]  # 16 dinucleotides in fixed alphabetical order\n",
        "\n",
        "\n",
        "def dinucleotide_frequencies(seq: str) -> dict:\n",
        "    \"\"\"\n",
        "    Compute the relative frequency of all 16 dinucleotides in the sequence.\n",
        "\n",
        "    Frequencies are normalised by the total number of dinucleotide windows\n",
        "    (= length - 1 = 19 for a 20-nt guide).\n",
        "\n",
        "    Parameters\n",
        "    ----------\n",
        "    seq : str  — validated 20-nt sequence\n",
        "\n",
        "    Returns\n",
        "    -------\n",
        "    dict  — keys are 2-character strings (e.g. 'AA', 'AC', …), values are\n",
        "            floats in [0, 1] summing to 1.0.\n",
        "    \"\"\"\n",
        "    n_windows = len(seq) - 1          # 19 for a 20-nt sequence\n",
        "    counts = Counter(seq[i:i+2] for i in range(n_windows))\n",
        "    return {di: counts.get(di, 0) / n_windows for di in ALL_DINUCLEOTIDES}\n"
      ],
      "metadata": {
        "id": "9lNNP6em2jQY"
      },
