        "if __name__ == \"__main__\":\n",
        "\n",
        "    # ── Recreate the Stage 1 output synthetically for standalone testing ───────\n",
        "    import random, math\n",
        "    from collections import Counter\n",
        "\n",
        "    random.seed(42)\n",
        "    np.random.seed(42)\n",
        "    BASES = \"ATGC\"\n",
        "\n",
        "    def _gc(seq):      return (seq.count(\"G\") + seq.count(\"C\")) / len(seq)\n",
        "    def _seed_gc(seq): return (seq[-10:].count(\"G\") + seq[-10:].count(\"C\")) / 10\n",
        "    def _hp(seq):\n",
        "        mx = cr = 1\n",
        "        for i in range(1, len(seq)):\n",
        "            cr = cr + 1 if seq[i] == seq[i-1] else 1\n",
        "            mx = max(mx, cr)\n",
        "        return mx\n",
        "    def _ent(seq):\n",
        "        c = Counter(seq); h = 0\n",
        "        for b in \"ATGC\":\n",
        "            p = c.get(b, 0) / len(seq)\n",
        "            if p: h -= p * math.log2(p)\n",
        "        return h\n",
        "    def _di(seq):\n",
        "        n = len(seq) - 1\n",
        "        c = Counter(seq[i:i+2] for i in range(n))\n",
        "        return {a+b: c.get(a+b, 0)/n for a in \"ATGC\" for b in \"ATGC\"}\n",
        "\n",
        "    N = 300\n",
        "    rows = []\n",
        "    for _ in range(N):\n",
        "        s = \"\".join(random.choices(BASES, k=20))\n",
        "        r = {\"sgRNA_sequence\": s, \"gene\": random.choice([\"TP53\",\"KRAS\",\"BRCA1\",\"EGFR\"]),\n",
        "             \"gc_content\": _gc(s), \"seed_gc_content\": _seed_gc(s),\n",
        "             \"longest_homopolymer\": _hp(s), \"sequence_entropy\": _ent(s)}\n",
        "        r.update({f\"dinuc_{k}\": v for k, v in _di(s).items()})\n",
        "        r[\"efficiency_score\"] = np.clip(0.6*_gc(s) + 0.2*_ent(s)/2 +\n",
        "                                        np.random.normal(0, 0.12), 0, 1)\n",
        "        rows.append(r)\n",
        "\n",
        "    ml_dataset = pd.DataFrame(rows)\n",
        "\n",
        "    # ── Run Stage 2 ───────────────────────────────────────────────────────────\n",
