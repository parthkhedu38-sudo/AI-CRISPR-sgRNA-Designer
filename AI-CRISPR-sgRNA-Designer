        "import shap\n",
        "import numpy as np\n",
        "\n",
        "def compute_shap_values(model: RandomForestRegressor,\n",
        "                         X: pd.DataFrame,\n",
        "                         sample_limit: int = 500) -> tuple:\n",
        "    \"\"\"\n",
        "    Compute exact SHAP values using TreeExplainer.\n",
        "\n",
        "    TreeExplainer exploits the tree structure to compute exact Shapley\n",
        "    values without sampling — far faster and more accurate than the\n",
        "    model-agnostic KernelExplainer for forest models.\n",
        "\n",
        "    If X has more than `sample_limit` rows, a random subsample is used\n",
        "    for the SHAP computation to keep runtime reasonable in Colab\n",
        "    (< 30 seconds for 500 samples × 100 features × 200 trees).\n",
        "\n",
        "    Parameters\n",
        "    ----------\n",
        "    model        : fitted RandomForestRegressor\n",
        "    X            : pd.DataFrame — full feature matrix\n",
        "    sample_limit : int          — max samples to explain (None = all)\n",
        "\n",
        "    Returns\n",
        "    -------\n",
        "    (explainer, shap_values, X_explained)\n",
        "        explainer   : shap.TreeExplainer  — carries the base_value\n",
        "        shap_values : np.ndarray          — shape (n_samples, n_features)\n",
        "        X_explained : pd.DataFrame        — the (sub)sample that was explained\n",
        "    \"\"\"\n",
        "    if sample_limit and len(X) > sample_limit:\n",
        "        print(f\"[shap] Dataset has {len(X):,} rows; \"\n",
        "              f\"sampling {sample_limit} for SHAP to keep runtime fast …\")\n",
        "        X_explained = X.sample(n=sample_limit, random_state=42).reset_index(drop=True)\n",
        "    else:\n",
        "        X_explained = X.reset_index(drop=True)\n",
        "\n",
        "    print(f\"[shap] Building TreeExplainer (exact, no sampling) …\")\n",
        "    explainer = shap.TreeExplainer(model)\n",
        "\n",
        "    print(f\"[shap] Computing SHAP values for {len(X_explained):,} samples …\")\n",
        "    shap_values = explainer.shap_values(X_explained)\n",
        "    # shap_values shape: (n_samples, n_features)\n",
        "\n",
        "    base_value = float(explainer.expected_value) # Convert to float\n",
        "    print(f\"[shap] Done.  Base value (mean prediction) = {base_value:.4f}\\n\")\n",
        "    return explainer, shap_values, X_explained\n",
