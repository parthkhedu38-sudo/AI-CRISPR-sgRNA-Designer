      "source": [
        "def cross_validate_multi_seed(X: pd.DataFrame,\n",
        "                               y: pd.Series,\n",
        "                               config: dict = CV_CONFIG) -> pd.DataFrame:\n",
        "    \"\"\"\n",
        "    Run K-fold cross-validation across ALL seeds in config['seeds'].\n",
        "\n",
        "    Each seed produces `n_splits` rows, so the final table has\n",
        "    len(seeds) × n_splits rows (25 rows with default settings).\n",
        "\n",
        "    This multi-seed approach separates two sources of variance:\n",
        "        • Variance due to data partitioning  (across folds)\n",
        "        • Variance due to model stochasticity (across seeds)\n",
        "\n",
        "    Parameters\n",
        "    ----------\n",
        "    X      : pd.DataFrame — feature matrix\n",
        "    y      : pd.Series    — target\n",
        "    config : dict         — CV_CONFIG\n",
        "\n",
        "    Returns\n",
        "    -------\n",
        "    pd.DataFrame  — aggregated results across all seeds × folds\n",
        "    \"\"\"\n",
        "    all_results = []\n",
        "    total = len(config[\"seeds\"]) * config[\"n_splits\"]\n",
        "    done  = 0\n",
        "\n",
        "    print(f\"[cv] Running {len(config['seeds'])} seeds × \"\n",
        "          f\"{config['n_splits']} folds = {total} total fits …\\n\")\n",
        "\n",
        "    for seed in config[\"seeds\"]:\n",
        "        seed_df = cross_validate_single_seed(X, y, seed, config)\n",
        "        all_results.append(seed_df)\n",
        "        done += config[\"n_splits\"]\n",
        "\n",
