        "def design_sgrnas(sequence:        str,\n",
        "                  model,\n",
        "                  feature_columns: list,\n",
        "                  top_n:           int  = 10,\n",
        "                  min_efficiency:  float = 0.0,\n",
        "                  both_strands:    bool  = True) -> pd.DataFrame:\n",
        "    \"\"\"\n",
        "    End-to-end sgRNA design pipeline.\n",
        "\n",
        "    Takes a raw DNA sequence and returns the top-N ranked guide RNAs\n",
        "    ready for experimental use, with predicted cutting efficiency scores.\n",
        "\n",
        "    Pipeline\n",
        "    ─────────\n",
        "        1. generate_sgrnas()           — PAM scanning (both strands)\n",
        "        2. predict_sgrna_efficiency()  — feature extraction + RF prediction\n",
        "        3. Filter by min_efficiency threshold\n",
        "        4. Return top_n candidates\n",
        "\n",
        "    Parameters\n",
        "    ----------\n",
        "    sequence        : str   — target DNA sequence (any length)\n",
        "    model           : fitted RandomForestRegressor\n",
        "    feature_columns : list  — training feature order\n",
        "    top_n           : int   — number of top guides to return (default 10)\n",
        "    min_efficiency  : float — minimum predicted efficiency filter (default 0.0)\n",
        "    both_strands    : bool  — if False, scan forward strand only\n",
        "\n",
        "    Returns\n",
        "    -------\n",
        "    pd.DataFrame  — top_n rows with columns:\n",
        "        rank | sgRNA_sequence | pam | position | strand |\n",
        "        context_30mer | predicted_efficiency\n",
        "    \"\"\"\n",
        "    print(\"=\" * 60)\n",
        "    print(\"sgRNA DESIGNER\")\n",
        "    print(\"=\" * 60)\n",
        "    print(f\"  Target length    : {len(sequence):,} bp\")\n",
        "    print(f\"  Top N requested  : {top_n}\")\n",
        "    print(f\"  Min efficiency   : {min_efficiency}\")\n",
        "    print(f\"  Both strands     : {both_strands}\\n\")\n",
        "\n",
        "    # ── Step 1: Scan for PAM sites ────────────────────────────────────────────\n",
        "    candidates = generate_sgrnas(sequence)\n",
        "\n",
        "    if not both_strands:\n",
        "        candidates = candidates[candidates[\"strand\"] == \"+\"].reset_index(drop=True)\n",
        "        print(f\"[design] Forward-strand only: {len(candidates):,} candidates\\n\")\n",
        "\n",
        "    if candidates.empty:\n",
        "        print(\"[design] ✗ No NGG PAM sites found in this sequence.\")\n",
        "        return pd.DataFrame()\n",
        "\n",
        "    # ── Step 2: Predict efficiency ────────────────────────────────────────────\n",
        "    ranked = predict_sgrna_efficiency(candidates, model, feature_columns)\n",
        "\n",
        "    # ── Step 3: Filter by minimum efficiency ─────────────────────────────────\n",
        "    if min_efficiency > 0:\n",
        "        before = len(ranked)\n",
        "        ranked = ranked[ranked[\"predicted_efficiency\"] >= min_efficiency]\n",
        "        print(f\"[design] Min-efficiency filter ({min_efficiency:.2f}): \"\n",
        "              f\"{before} → {len(ranked)} candidates\\n\")\n",
        "\n",
        "    if ranked.empty:\n",
        "        print(f\"[design] ✗ No candidates passed the efficiency threshold \"\n",
        "              f\"({min_efficiency:.2f}).\")\n",
        "        return pd.DataFrame()\n",
        "\n",
        "    # ── Step 4: Select top N ─────────────────────────────────────────────────\n",
        "    top = ranked.head(top_n).copy()\n",
        "    top[\"rank\"] = range(1, len(top) + 1)\n",
        "\n",
        "    print(f\"[design] Top {len(top)} sgRNAs selected.\\n\")\n",
        "    return top"
      ],
