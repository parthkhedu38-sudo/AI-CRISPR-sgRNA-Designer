        "def flag_off_target_risk(top_df: pd.DataFrame) -> pd.DataFrame:\n",
        "    \"\"\"\n",
        "    Attach lightweight heuristic off-target risk flags to each candidate.\n",
        "\n",
        "    These are NOT a substitute for full off-target prediction tools\n",
        "    (e.g. Cas-OFFinder, CRISPRscan), but provide a quick first-pass\n",
        "    filter based on well-known sequence rules:\n",
        "\n",
        "        HIGH GC (>75%)     — more likely to bind off-target loci\n",
        "        LOW GC  (<25%)     — unstable on-target; probably already low efficiency\n",
        "        Poly-T  (TTTT+)    — RNA Pol III termination, likely non-functional\n",
        "        Poly-G  (GGGG+)    — G-quadruplex risk in the guide RNA\n",
        "        Seed homopolymer   — run of ≥3 identical bases in positions 17-20\n",
        "\n",
        "    Parameters\n",
        "    ----------\n",
        "    top_df : pd.DataFrame — output of design_sgrnas()\n",
        "\n",
        "    Returns\n",
        "    -------\n",
        "    pd.DataFrame — copy with 'risk_flags' column added\n",
        "    \"\"\"\n",
        "    flags_list = []\n",
        "    for _, row in top_df.iterrows():\n",
        "        seq   = row[\"sgRNA_sequence\"]\n",
        "        flags = []\n",
        "\n",
        "        gc = (seq.count(\"G\") + seq.count(\"C\")) / 20\n",
        "        if gc > 0.75:\n",
        "            flags.append(\"high-GC\")\n",
        "        if gc < 0.25:\n",
        "            flags.append(\"low-GC\")\n",
        "        if \"TTTT\" in seq:\n",
        "            flags.append(\"poly-T\")\n",
        "        if \"GGGG\" in seq:\n",
        "            flags.append(\"poly-G\")\n",
        "\n",
        "        # Seed region homopolymer (positions 17-20, 0-indexed 16:20)\n",
        "        seed = seq[16:]\n",
        "        if len(set(seed)) == 1:\n",
        "            flags.append(\"seed-homopolymer\")\n",
        "\n",
        "        flags_list.append(\", \".join(flags) if flags else \"none\")\n",
        "\n",
        "    result = top_df.copy()\n",
        "    result[\"risk_flags\"] = flags_list\n",
        "    return result"
      ],
