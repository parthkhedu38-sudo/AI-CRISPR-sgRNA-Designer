        "VALID_BASES    = set(\"ATGC\")\n",
        "REQUIRED_LEN   = 20\n",
        "\n",
        "\n",
        "def validate_sequences(df: pd.DataFrame,\n",
        "                        seq_col: str = SEQ_COL) -> pd.DataFrame:\n",
        "    \"\"\"\n",
        "    Enforce the same validation rules used in Stage 1 of the pipeline:\n",
        "        • Length must equal 20 nt\n",
        "        • Characters must be a subset of {A, T, G, C}\n",
        "\n",
        "    Parameters\n",
        "    ----------\n",
        "    df      : pd.DataFrame\n",
        "    seq_col : str\n",
        "\n",
        "    Returns\n",
        "    -------\n",
        "    pd.DataFrame — valid rows only, sequences normalised to uppercase\n",
        "    \"\"\"\n",
        "    df = df.copy()\n",
        "    df[seq_col] = df[seq_col].str.upper().str.strip()\n",
        "\n",
        "    valid = (\n",
        "        df[seq_col].str.len().eq(REQUIRED_LEN) &\n",
        "        df[seq_col].apply(lambda s: set(s).issubset(VALID_BASES)\n",
        "                          if isinstance(s, str) else False)\n",
        "    )\n",
        "    n_invalid = (~valid).sum()\n",
        "    if n_invalid:\n",
        "        print(f\"[validate] ⚠ Dropping {n_invalid} invalid sequence(s).\")\n",
        "    else:\n",
        "        print(f\"[validate] ✓ All sequences are valid 20-nt ATGC strings.\")\n",
        "\n",
        "    return df[valid].reset_index(drop=True)"
      ],
