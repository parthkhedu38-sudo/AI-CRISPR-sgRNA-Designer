        "def build_shap_importance_table(shap_values: np.ndarray,\n",
        "                                 X_explained: pd.DataFrame) -> pd.DataFrame:\n",
        "    \"\"\"\n",
        "    Aggregate per-sample SHAP values into a global importance table.\n",
        "\n",
        "    Global importance of feature f  =  mean |SHAP_f|  across all samples.\n",
        "\n",
        "    This is the SHAP analogue of RandomForest's mean-decrease-in-impurity,\n",
        "    but with a key advantage: it is additive and directional, so we also\n",
        "    track the mean signed SHAP to see which features push predictions up\n",
        "    vs down on average.\n",
        "\n",
        "    Columns returned\n",
        "    ────────────────\n",
        "    feature             : feature name\n",
        "    mean_abs_shap       : global importance (always ≥ 0)\n",
        "    mean_shap           : directional average (positive = increases efficiency)\n",
        "    feature_type        : 'positional' | 'biological'\n",
        "    position            : integer 1-20 for positional features, NaN otherwise\n",
        "    base                : nucleotide (A/T/G/C) for positional features\n",
        "    rank                : 1 = most important\n",
        "\n",
        "    Parameters\n",
        "    ----------\n",
        "    shap_values : np.ndarray   — (n_samples, n_features)\n",
        "    X_explained : pd.DataFrame — the explained sample (needed for column names)\n",
        "\n",
        "    Returns\n",
        "    -------\n",
        "    pd.DataFrame  — sorted by mean_abs_shap descending\n",
        "    \"\"\"\n",
        "    feature_names = list(X_explained.columns)\n",
        "    mean_abs = np.abs(shap_values).mean(axis=0)\n",
        "    mean_sig = shap_values.mean(axis=0)\n",
        "\n",
        "    rows = []\n",
        "    for fname, ma, ms in zip(feature_names, mean_abs, mean_sig):\n",
        "        is_pos  = fname.startswith(\"pos\")\n",
        "        pos_num = int(fname[3:5])         if is_pos else np.nan\n",
        "        base    = fname.split(\"_\")[1]     if is_pos else np.nan\n",
        "        rows.append({\n",
        "            \"feature\"      : fname,\n",
        "            \"mean_abs_shap\": round(ma, 7),\n",
        "            \"mean_shap\"    : round(ms, 7),\n",
        "            \"feature_type\" : \"positional\" if is_pos else \"biological\",\n",
        "            \"position\"     : pos_num,\n",
        "            \"base\"         : base,\n",
        "        })\n",
        "\n",
        "    imp_df = (pd.DataFrame(rows)\n",
        "                .sort_values(\"mean_abs_shap\", ascending=False)\n",
        "                .reset_index(drop=True))\n",
        "    imp_df[\"rank\"] = imp_df.index + 1\n",
        "    return imp_df"
      ],
