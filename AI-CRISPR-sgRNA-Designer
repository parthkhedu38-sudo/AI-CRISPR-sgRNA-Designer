        "def train_full_model(X: pd.DataFrame,\n",
        "                     y: pd.Series,\n",
        "                     n_estimators: int = 200,\n",
        "                     min_samples_leaf: int = 2,\n",
        "                     random_state: int = 42) -> RandomForestRegressor:\n",
        "    \"\"\"\n",
        "    Train a RandomForestRegressor on the COMPLETE dataset.\n",
        "\n",
        "    For SHAP analysis we deliberately use all data — we are not evaluating\n",
        "    held-out generalisation here but explaining what the model learned.\n",
        "    A train/test split is still shown for honest reporting, but SHAP\n",
        "    values are computed over all samples so every guide gets an explanation.\n",
        "\n",
        "    Parameters\n",
        "    ----------\n",
        "    X               : pd.DataFrame — full feature matrix (100 cols)\n",
        "    y               : pd.Series    — efficiency_score\n",
        "    n_estimators    : int\n",
        "    min_samples_leaf: int\n",
        "    random_state    : int\n",
        "\n",
        "    Returns\n",
        "    -------\n",
        "    RandomForestRegressor — fitted on full X, y\n",
        "    \"\"\"\n",
        "    print(f\"[model] Training RandomForest on {X.shape[0]:,} samples, \"\n",
        "          f\"{X.shape[1]} features …\")\n",
        "\n",
        "    model = RandomForestRegressor(\n",
        "        n_estimators     = n_estimators,\n",
        "        min_samples_leaf = min_samples_leaf,\n",
        "        max_depth        = None,\n",
        "        random_state     = random_state,\n",
        "        n_jobs           = -1\n",
        "    )\n",
        "    model.fit(X, y)\n",
        "\n",
        "    # Quick honesty check: train R² so we know what the model captured\n",
        "    train_r2 = r2_score(y, model.predict(X))\n",
        "    print(f\"[model] Train R² = {train_r2:.4f}  \"\n",
        "          f\"(in-sample; used only to confirm model is not trivially flat)\\n\")\n",
        "    return model"
      ],
