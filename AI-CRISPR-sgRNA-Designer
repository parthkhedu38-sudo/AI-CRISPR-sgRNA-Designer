        "def compute_sample_weights(penalties: pd.Series,\n",
        "                             min_weight: float = 0.20) -> np.ndarray:\n",
        "    \"\"\"\n",
        "    Convert penalties to sample weights for RandomForest.fit(sample_weight=…).\n",
        "\n",
        "    Weight formula:\n",
        "        w[i]  =  max(1 − penalty[i],  min_weight)\n",
        "\n",
        "    min_weight ensures no sample is completely ignored (avoids instability).\n",
        "    A sample with penalty = 0  gets weight 1.0  (full influence).\n",
        "    A sample with penalty = 1  gets weight 0.20 (reduced but non-zero).\n",
        "\n",
        "    Biological effect: trees are built on bootstrap samples where\n",
        "    biologically implausible guides appear less often, so split decisions\n",
        "    are driven by 'good' sequences → lower overfitting on outliers.\n",
        "\n",
        "    Parameters\n",
        "    ----------\n",
        "    penalties  : pd.Series — bio_penalty values\n",
        "    min_weight : float     — floor weight for maximally penalised samples\n",
        "\n",
        "    Returns\n",
        "    -------\n",
        "    np.ndarray  — weights aligned with penalties index\n",
        "    \"\"\"\n",
        "    weights = np.maximum(1.0 - penalties.values, min_weight)\n",
        "    print(f\"[weights] Sample weights computed.\")\n",
        "    print(f\"          Min weight : {weights.min():.4f}  \"\n",
        "          f\"Max weight : {weights.max():.4f}  \"\n",
        "          f\"Mean : {weights.mean():.4f}\\n\")\n",
        "    return weights"
      ],
      "metadata": {
        "id": "VtHmyff47K92"
      },
      "execution_count": null,
      "outputs": []
