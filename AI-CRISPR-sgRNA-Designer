        "def print_feature_importance_table(model: RandomForestRegressor,\n",
        "                                   feature_names: list) -> pd.DataFrame:\n",
        "    \"\"\"\n",
        "    Return a ranked DataFrame of feature importances and print it.\n",
        "\n",
        "    Parameters\n",
        "    ----------\n",
        "    model         : fitted RandomForestRegressor\n",
        "    feature_names : list of str\n",
        "\n",
        "    Returns\n",
        "    -------\n",
        "    pd.DataFrame  — columns: feature, importance, cumulative_importance\n",
        "    \"\"\"\n",
        "    imp_df = (\n",
        "        pd.DataFrame({\n",
        "            \"feature\"   : feature_names,\n",
        "            \"importance\": model.feature_importances_,\n",
        "        })\n",
        "        .sort_values(\"importance\", ascending=False)\n",
        "        .reset_index(drop=True)\n",
        "    )\n",
        "    imp_df[\"cumulative_importance\"] = imp_df[\"importance\"].cumsum().round(4)\n",
        "    imp_df[\"importance\"] = imp_df[\"importance\"].round(5)\n",
        "\n",
        "    print(\"[importance] Full feature ranking:\")\n",
        "    print(imp_df.to_string(index=False))\n",
        "    print()\n",
        "    return imp_df\n",
        "\n"
      ],
