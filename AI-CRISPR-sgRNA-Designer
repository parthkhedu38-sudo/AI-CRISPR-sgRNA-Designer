    },
    {
      "cell_type": "code",
      "source": [
        "def seed_gc_content(seq: str, seed_length: int = 10) -> float:\n",
        "    \"\"\"\n",
        "    Compute GC content of the PAM-proximal seed region (last `seed_length` bases).\n",
        "\n",
        "    The seed region (positions 11-20 counting from the 5' end) is the most\n",
        "    critical for Cas9 binding and cleavage efficiency.\n",
        "\n",
        "    Parameters\n",
        "    ----------\n",
        "    seq         : str  — validated 20-nt sequence\n",
        "    seed_length : int  — number of 3'-terminal bases to consider (default 10)\n",
        "\n",
        "    Returns\n",
        "    -------\n",
        "    float in [0, 1]\n",
        "    \"\"\"\n",
        "    seed = seq[-seed_length:]\n",
        "    return (seed.count(\"G\") + seed.count(\"C\")) / len(seed)"
      ],
