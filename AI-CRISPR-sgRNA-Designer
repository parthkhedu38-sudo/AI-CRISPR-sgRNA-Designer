        "def print_position_importance(model: RandomForestRegressor,\n",
        "                               feature_names: list) -> pd.DataFrame:\n",
        "    \"\"\"\n",
        "    Aggregate per-base importance back to position level.\n",
        "\n",
        "    For each position i, sum the importances of pos{i}_A, pos{i}_T,\n",
        "    pos{i}_G, pos{i}_C to get a single 'how important is this position'\n",
        "    score. Helps identify whether the seed region (pos 17–20) dominates,\n",
        "    consistent with known Cas9 biology.\n",
        "\n",
        "    Parameters\n",
        "    ----------\n",
        "    model         : fitted RandomForestRegressor (on enhanced features)\n",
        "    feature_names : list of str  — must include positional columns\n",
        "\n",
        "    Returns\n",
        "    -------\n",
        "    pd.DataFrame  — columns: position, total_importance, rank\n",
        "                    sorted by importance descending\n",
        "    \"\"\"\n",
        "    imp = pd.Series(model.feature_importances_, index=feature_names)\n",
        "    pos_rows = []\n",
        "\n",
        "    for pos_idx in range(1, SEQ_LENGTH + 1):\n",
        "        prefix = f\"pos{pos_idx:02d}_\"\n",
        "        total  = imp[[c for c in feature_names if c.startswith(prefix)]].sum()\n",
        "        region = (\"5′ distal (1–4)\"   if pos_idx <= 4  else\n",
        "                  \"middle (5–16)\"     if pos_idx <= 16 else\n",
        "                  \"seed/PAM-prox (17–20)\")\n",
        "        pos_rows.append({\"position\": pos_idx, \"region\": region,\n",
        "                         \"total_importance\": round(total, 6)})\n",
        "\n",
        "    pos_df = (pd.DataFrame(pos_rows)\n",
        "                .sort_values(\"total_importance\", ascending=False)\n",
        "                .reset_index(drop=True))\n",
        "    pos_df[\"rank\"] = pos_df.index + 1\n",
        "\n",
        "    print(\"POSITION-LEVEL IMPORTANCE SUMMARY\")\n",
        "    print(\"─\" * 52)\n",
        "    print(pos_df[[\"rank\",\"position\",\"region\",\"total_importance\"]].to_string(index=False))\n",
        "    print()\n",
        "    return pos_df"
      ],
