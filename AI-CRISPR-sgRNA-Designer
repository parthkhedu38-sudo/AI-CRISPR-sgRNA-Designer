    {
      "cell_type": "code",
      "source": [
        "CV_CONFIG = {\n",
        "    \"n_splits\"       : 5,\n",
        "    \"seeds\"          : [0, 7, 21, 42, 99],\n",
        "    \"n_estimators\"   : 200,\n",
        "    \"min_samples_leaf\": 2,\n",
        "    \"max_depth\"      : None,\n",
        "}\n",
        "\n",
        "\n",
        "def _cv_run(X: pd.DataFrame,\n",
        "             y: pd.Series,\n",
        "             config: dict,\n",
        "             label: str,\n",
        "             sample_weights: np.ndarray = None,\n",
        "             posthoc_penalties: np.ndarray = None,\n",
        "             posthoc_beta: float = 0.15) -> pd.DataFrame:\n",
        "    \"\"\"\n",
        "    Run K-fold CV × multiple seeds.  Supports optional sample_weights and\n",
        "    post-hoc penalty adjustment.\n",
        "\n",
        "    Records train + test R² and MSE per fold so overfitting gap is visible.\n",
        "    If posthoc_penalties is provided, the test predictions are adjusted\n",
        "    via apply_posthoc_penalty() before metric computation.\n",
        "\n",
        "    Parameters\n",
        "    ----------\n",
        "    X                  : pd.DataFrame\n",
        "    y                  : pd.Series      — (possibly smoothed) target\n",
        "    config             : dict           — CV_CONFIG\n",
        "    label              : str            — run label for the results table\n",
        "    sample_weights     : np.ndarray | None — per-sample weights aligned with X\n",
        "    posthoc_penalties  : np.ndarray | None — penalties for post-hoc adjustment\n",
        "    posthoc_beta       : float\n",
        "\n",
        "    Returns\n",
        "    -------\n",
        "    pd.DataFrame  — columns: label, seed, fold, r2_train, mse_train,\n",
        "                                                 r2_test,  mse_test\n",
        "    \"\"\"\n",
        "    records = []\n",
        "    total   = len(config[\"seeds\"]) * config[\"n_splits\"]\n",
        "    done    = 0\n",
        "    print(f\"[cv:{label}] {len(config['seeds'])} seeds × \"\n",
        "          f\"{config['n_splits']} folds = {total} fits …\")\n",
        "\n",
        "    for seed in config[\"seeds\"]:\n",
        "        kf = KFold(n_splits=config[\"n_splits\"], shuffle=True, random_state=seed)\n",
        "\n",
        "        for fold_idx, (tr_idx, te_idx) in enumerate(kf.split(X), start=1):\n",
        "            X_tr, X_te = X.iloc[tr_idx], X.iloc[te_idx]\n",
        "            y_tr, y_te = y.iloc[tr_idx], y.iloc[te_idx]\n",
        "\n",
        "            # Slice sample weights if provided\n",
        "            sw_tr = sample_weights[tr_idx] if sample_weights is not None else None\n",
        "\n",
        "            model = RandomForestRegressor(\n",
        "                n_estimators     = config[\"n_estimators\"],\n",
        "                min_samples_leaf = config[\"min_samples_leaf\"],\n",
        "                max_depth        = config[\"max_depth\"],\n",
        "                random_state     = seed,\n",
        "                n_jobs           = -1,\n",
        "            )\n",
        "            model.fit(X_tr, y_tr, sample_weight=sw_tr)\n",
        "\n",
        "            y_pred_tr = model.predict(X_tr)\n",
        "            y_pred_te = model.predict(X_te)\n",
        "\n",
        "            # Optional post-hoc penalty on test predictions\n",
        "            if posthoc_penalties is not None:\n",
        "                pp_te    = posthoc_penalties[te_idx]\n",
        "                y_pred_te = apply_posthoc_penalty(y_pred_te, pp_te, posthoc_beta)\n",
        "\n",
        "            records.append({\n",
        "                \"label\"    : label,\n",
        "                \"seed\"     : seed,\n",
        "                \"fold\"     : fold_idx,\n",
        "                \"r2_train\" : r2_score(y_tr, y_pred_tr),\n",
        "                \"mse_train\": mean_squared_error(y_tr, y_pred_tr),\n",
        "                \"r2_test\"  : r2_score(y_te, y_pred_te),\n",
        "                \"mse_test\" : mean_squared_error(y_te, y_pred_te),\n",
        "            })\n",
        "            done += 1\n",
        "\n",
        "        seed_rows  = [r for r in records\n",
        "                      if r[\"seed\"] == seed and r[\"label\"] == label]\n",
        "        mean_r2_te = np.mean([r[\"r2_test\"] for r in seed_rows])\n",
        "        print(f\"  seed={seed:>3d}  mean test R²={mean_r2_te:.4f}  \"\n",
        "              f\"[{done}/{total}]\")\n",
        "\n",
        "    print(f\"[cv:{label}] Done.\\n\")\n",
        "    return pd.DataFrame(records)"
      ],
