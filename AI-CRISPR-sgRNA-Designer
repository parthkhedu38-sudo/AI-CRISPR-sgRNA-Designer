        "    BASES = \"ATGC\"\n",
        "\n",
        "    # ── Re-create a Stage-1-style ml_dataset synthetically ───────────────────\n",
        "    def _gc(s):  return (s.count(\"G\") + s.count(\"C\")) / len(s)\n",
        "    def _sgc(s): return (s[-10:].count(\"G\") + s[-10:].count(\"C\")) / 10\n",
        "    def _hp(s):\n",
        "        mx = cr = 1\n",
        "        for i in range(1, len(s)):\n",
        "            cr = cr+1 if s[i]==s[i-1] else 1; mx = max(mx, cr)\n",
        "        return mx\n",
        "    def _ent(s):\n",
        "        c = Counter(s); h = 0\n",
        "        for b in \"ATGC\":\n",
        "            p = c.get(b,0)/len(s)\n",
        "            if p: h -= p*math.log2(p)\n",
        "        return h\n",
        "    def _di(s):\n",
        "        n = len(s)-1; c = Counter(s[i:i+2] for i in range(n))\n",
        "        return {a+b: c.get(a+b,0)/n for a in \"ATGC\" for b in \"ATGC\"}\n",
        "\n",
        "    N = 400\n",
        "    rows = []\n",
        "    for _ in range(N):\n",
        "        s = \"\".join(random.choices(BASES, k=20))\n",
        "        # Simulate a realistic efficiency signal:\n",
        "        # seed GC (pos 17-20) contributes most, then overall GC, then noise\n",
        "        seed_effect = 0.5 * _sgc(s)\n",
        "        gc_effect   = 0.3 * _gc(s)\n",
        "        pos1_g      = 0.1 * (s[0] == \"G\")     # G at pos1 → U6 expression\n",
        "        noise       = np.random.normal(0, 0.10)\n",
        "        eff         = float(np.clip(seed_effect + gc_effect + pos1_g + noise, 0, 1))\n",
        "\n",
        "        r = {\"sgRNA_sequence\": s,\n",
        "             \"gene\": random.choice([\"TP53\", \"KRAS\", \"BRCA1\", \"EGFR\"]),\n",
        "             \"gc_content\": _gc(s), \"seed_gc_content\": _sgc(s),\n",
        "             \"longest_homopolymer\": _hp(s), \"sequence_entropy\": _ent(s)}\n",
        "        r.update({f\"dinuc_{k}\": v for k, v in _di(s).items()})\n",
        "        r[\"efficiency_score\"] = round(eff, 4)\n",
