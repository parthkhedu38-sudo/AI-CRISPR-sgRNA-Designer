        "def print_biological_report(imp_df: pd.DataFrame,\n",
        "                              pos_rollup: pd.DataFrame,\n",
        "                              base_val: float,\n",
        "                              top_n: int = 10) -> None:\n",
        "    \"\"\"\n",
        "    Print a plain-language biological interpretation of the SHAP results.\n",
        "\n",
        "    Translates SHAP rankings into biologically meaningful statements\n",
        "    about Cas9 specificity, guide design rules, and position effects.\n",
        "\n",
        "    Parameters\n",
        "    ----------\n",
        "    imp_df     : pd.DataFrame — global importance table\n",
        "    pos_rollup : pd.DataFrame — per-position rollup\n",
        "    base_val   : float        — model's base prediction (mean efficiency)\n",
        "    top_n      : int          — features to describe\n",
        "    \"\"\"\n",
        "    print(\"=\" * 70)\n",
        "    print(\"BIOLOGICAL INTERPRETATION — SHAP ANALYSIS\")\n",
        "    print(\"=\" * 70)\n",
        "    print(f\"\\n  Model baseline (average predicted efficiency): {base_val:.4f}\")\n",
        "    print(f\"  Any SHAP > 0 pushes a guide ABOVE this baseline.\")\n",
        "    print(f\"  Any SHAP < 0 pushes a guide BELOW this baseline.\\n\")\n",
        "\n",
        "    # Top overall features\n",
        "    top_features = imp_df.head(top_n)\n",
        "    print(f\"  TOP {top_n} PREDICTIVE FEATURES:\")\n",
        "    print(f\"  {'Rank':<6}{'Feature':<22}{'Type':<14}\"\n",
        "          f\"{'Mean|SHAP|':>12}{'Direction':>12}\")\n",
        "    print(f\"  {'─'*64}\")\n",
        "    for _, row in top_features.iterrows():\n",
        "        direction = \"↑ efficiency\" if row[\"mean_shap\"] > 0 else \"↓ efficiency\"\n",
        "        print(f\"  {int(row['rank']):<6}{row['feature']:<22}\"\n",
        "              f\"{row['feature_type']:<14}\"\n",
        "              f\"{row['mean_abs_shap']:>12.6f}\"\n",
        "              f\"{direction:>12}\")\n",
        "\n",
        "    # Seed region analysis\n",
        "    seed_rows = pos_rollup[pos_rollup[\"position\"] >= 17].sort_values(\"position\")\n",
        "    print(f\"\\n  SEED REGION (positions 17–20, PAM-proximal):\")\n",
        "    for _, row in seed_rows.iterrows():\n",
        "        pos_rank = int(row[\"rank\"])\n",
        "        print(f\"    Position {int(row['position']):>2}  |  \"\n",
        "              f\"total |SHAP| = {row['total_shap']:.6f}  |  \"\n",
        "              f\"dominant base: {row['dominant_base']}  |  \"\n",
        "              f\"overall position rank: #{pos_rank}\")\n",
        "\n",
        "    seed_total = pos_rollup[pos_rollup[\"position\"] >= 17][\"total_shap\"].sum()\n",
        "    all_total  = pos_rollup[\"total_shap\"].sum()\n",
        "    seed_pct   = 100 * seed_total / all_total if all_total > 0 else 0\n",
        "    print(f\"    → Seed region contributes {seed_pct:.1f}% of total positional SHAP.\")\n",
        "    print(f\"      (Expected >25% if PAM-proximal sensitivity is captured.)\\n\")\n",
        "\n",
        "    # Position 1 (U6 effect)\n",
        "    pos1 = pos_rollup[pos_rollup[\"position\"] == 1].iloc[0]\n",
        "    print(f\"  POSITION 1 (U6 promoter effect):\")\n",
        "    print(f\"    Total |SHAP| = {pos1['total_shap']:.6f}  |  \"\n",
        "          f\"dominant base: {pos1['dominant_base']}\")\n",
        "    print(f\"    (G at position 1 is preferred for U6 promoter transcription.)\\n\")\n",
        "\n",
        "    # Biological vs positional share\n",
        "    bio_share = imp_df[imp_df[\"feature_type\"] == \"biological\"][\"mean_abs_shap\"].sum()\n",
        "    pos_share = imp_df[imp_df[\"feature_type\"] == \"positional\"][\"mean_abs_shap\"].sum()\n",
        "    total_shap = bio_share + pos_share\n",
        "    print(f\"  FEATURE TYPE CONTRIBUTIONS (global |SHAP| share):\")\n",
