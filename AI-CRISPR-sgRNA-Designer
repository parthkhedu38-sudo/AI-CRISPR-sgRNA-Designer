        "def explain_penalty_breakdown(df: pd.DataFrame,\n",
        "                                n_examples: int = 5) -> None:\n",
        "    \"\"\"\n",
        "    Print penalty sub-component breakdown for the most penalised guides.\n",
        "\n",
        "    Useful for debugging: shows exactly which rule triggered the penalty\n",
        "    for specific sequences so researchers can audit or adjust thresholds.\n",
        "\n",
        "    Parameters\n",
        "    ----------\n",
        "    df         : pd.DataFrame — dataset with bio_penalty column\n",
        "    n_examples : int          — how many top-penalised guides to show\n",
        "    \"\"\"\n",
        "    top = df.nlargest(n_examples, \"bio_penalty\")\n",
        "    print(f\"TOP {n_examples} MOST PENALISED GUIDES\")\n",
        "    print(\"─\" * 80)\n",
        "    for _, row in top.iterrows():\n",
        "        gc   = row.get(\"gc_content\",          np.nan)\n",
        "        sgc  = row.get(\"seed_gc_content\",     np.nan)\n",
        "        hp   = int(row.get(\"longest_homopolymer\", 0))\n",
        "        seq  = row.get(\"sgRNA_sequence\",      \"N/A\")\n",
        "        eff  = row.get(\"efficiency_score\",    np.nan)\n",
        "        pen  = row.get(\"bio_penalty\",         np.nan)\n",
        "\n",
        "        p_gc   = compute_gc_penalty(gc)   * PENALTY_CONFIG[\"w_gc\"]\n",
        "        p_seed = compute_seed_penalty(sgc) * PENALTY_CONFIG[\"w_seed\"]\n",
        "        p_hp   = compute_homopolymer_penalty(hp) * PENALTY_CONFIG[\"w_hp\"]\n",
        "\n",
        "        print(f\"  Seq       : {seq}\")\n",
        "        print(f\"  Efficiency: {eff:.4f}   Total penalty: {pen:.4f}\")\n",
        "        print(f\"  GC={gc:.2f} → P_gc={p_gc:.4f}  |  \"\n",
        "              f\"SeedGC={sgc:.2f} → P_seed={p_seed:.4f}  |  \"\n",
        "              f\"HP={hp} → P_hp={p_hp:.4f}\")\n",
        "        print()"
      ],
